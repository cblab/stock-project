# External repos: keep only an optional folder README.
/repos/*
!/repos/README.md

# Local model files and downloaded weights: keep only an optional folder README.
/models/*
!/models/README.md

# Generated pipeline runs and local caches.
/runs/
/runs/**
/.deps/
/.cache/
/.hf-cache/

# Environment files and secrets.
.env
.env.*
*.env

# Python caches, virtualenvs, and build outputs.
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/

# Jupyter and test artifacts.
.ipynb_checkpoints/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Logs.
*.log
logs/
*.out
*.err

# OS and editor files.
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Temporary files.
tmp/
temp/
*.tmp
*.bak
