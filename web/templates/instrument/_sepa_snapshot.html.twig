<section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h2 class="text-sm font-semibold uppercase text-slate-500">Specific Entry Point Analysis / Minervini Snapshot</h2>
            <p class="mt-1 text-sm text-slate-600">Struktur- und Execution-Bewertung: Trend, relative Staerke, Base, VCP, Mikrostruktur und Setup-Timing.</p>
        </div>
        {% if sepaSnapshot %}
            {% set lightClasses = sepaSnapshot.trafficLight == 'Gruen'
                ? 'bg-emerald-50 text-emerald-800 ring-emerald-200'
                : (sepaSnapshot.trafficLight == 'Gelb' ? 'bg-amber-50 text-amber-800 ring-amber-200' : 'bg-rose-50 text-rose-800 ring-rose-200') %}
            <span class="w-fit rounded-full px-3 py-1 text-xs font-semibold ring-1 {{ lightClasses }}">{{ sepaSnapshot.trafficLight }}</span>
        {% endif %}
    </div>

    {% if sepaSnapshot %}
        {% set detail = sepaSnapshot.detailJson %}
        {% set weights = detail.phase1_model.weights ?? {} %}
        {% set scoreItems = [
            ['Markt', sepaSnapshot.marketScore, weights.market ?? null, 'Bewertet, wie konstruktiv das uebergeordnete Marktumfeld fuer Long-Setups ist.'],
            ['Stage', sepaSnapshot.stageScore, weights.stage ?? null, 'Bewertet die mittelfristige Trendstruktur, etwa Kurslage relativ zu 50- und 200-Tage-Linie.'],
            ['Relative Staerke', sepaSnapshot.relativeStrengthScore, weights.relative_strength ?? null, 'Misst, wie stark sich die Aktie relativ zum Markt und anderen Titeln verhaelt.'],
            ['Base', sepaSnapshot.baseQualityScore, weights.base_quality ?? null, 'Bewertet, ob die aktuelle Konsolidierung sauber, kontrolliert und konstruktiv wirkt.'],
            ['Volumen', sepaSnapshot.volumeScore, weights.volume ?? null, 'Prueft, ob das Volumenverhalten eher Akkumulation oder Distribution signalisiert.'],
            ['Momentum', sepaSnapshot.momentumScore, weights.momentum ?? null, 'Misst Staerke und Stabilitaet der juengsten Kursdynamik.'],
            ['Risiko', sepaSnapshot.riskScore, weights.risk ?? null, 'Bewertet, wie attraktiv das aktuelle Chancen-/Risikoprofil des Setups ist.'],
            ['Superperformance', sepaSnapshot.superperformanceScore, weights.superperformance ?? null, 'Schaetzt das Potenzial fuer Fuehrungsaktien-Qualitaet und klare Outperformance ein.']
        ] %}
        {% set executionWeights = detail.execution_layer.weights ?? detail.phase1_model.execution_layer.weights ?? {} %}
        {% set executionItems = [
            ['VCP', sepaSnapshot.vcpScore, executionWeights.vcp ?? null, detail.execution_layer.scores.vcp ?? detail.scores.vcp ?? {}, 'Bewertet die Kontraktionsfolge der Base: Pullbacks und Volatilitaet sollten konstruktiv enger werden.'],
            ['Mikrostruktur', sepaSnapshot.microstructureScore, executionWeights.microstructure ?? null, detail.execution_layer.scores.microstructure ?? detail.scores.microstructure ?? {}, 'Bewertet das kurzfristige Verhalten: gruen/rot-Tage, Pullbacks, Range-Struktur und Up/Down-Volumen.'],
            ['Breakout Readiness', sepaSnapshot.breakoutReadinessScore, executionWeights.breakout_readiness ?? null, detail.execution_layer.scores.breakout_readiness ?? detail.scores.breakout_readiness ?? {}, 'Bewertet, ob das Setup nahe und sauber an einem Pivot/Trigger liegt oder bereits zu spaet und gestreckt ist.']
        ] %}

        <div class="mt-4 grid gap-3 md:grid-cols-5">
            <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs uppercase text-slate-500">Total Score</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950">{{ sepaSnapshot.totalScore|number_format(1) }}</p>
                <p class="text-xs text-slate-500">0-100</p>
            </div>
            <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs uppercase text-slate-500">Structure</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950">{{ sepaSnapshot.structureScore|number_format(1) }}</p>
                <p class="text-xs text-slate-500">Trendqualitaet</p>
            </div>
            <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs uppercase text-slate-500">Execution</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950">{{ sepaSnapshot.executionScore|number_format(1) }}</p>
                <p class="text-xs text-slate-500">Setup-Timing</p>
            </div>
            <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs uppercase text-slate-500">As of</p>
                <p class="mt-1 font-semibold text-slate-950">{{ sepaSnapshot.asOfDate|date('d.m.Y') }}</p>
            </div>
            <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs uppercase text-slate-500">Marktdaten</p>
                <p class="mt-1 font-semibold text-slate-950">{{ detail.market_data_status ?? '-' }}{% if detail.market_data_rows is defined %} / {{ detail.market_data_rows }} Zeilen{% endif %}</p>
            </div>
            <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs uppercase text-slate-500">Modell</p>
                <p class="mt-1 font-semibold text-slate-950">Structure + Execution</p>
                <p class="text-xs text-slate-500">deterministisch</p>
            </div>
        </div>

        <h3 class="mt-5 text-sm font-semibold text-slate-950">Structure Layer</h3>
        <div class="mt-5 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
            {% for item in scoreItems %}
                <div class="rounded-md border border-slate-200 p-3">
                    <div class="flex items-center justify-between gap-3">
                        <p class="text-sm font-medium text-slate-700 underline decoration-dotted underline-offset-4" title="{{ item[3] }}">{{ item[0] }}</p>
                        <p class="text-sm font-semibold text-slate-950">{{ item[1]|number_format(1) }}</p>
                    </div>
                    <div class="mt-2 h-2 rounded-full bg-slate-100">
                        <div class="h-2 rounded-full bg-emerald-500" style="width: {{ item[1] }}%"></div>
                    </div>
                    {% if item[2] is not null %}
                        <p class="mt-1 text-xs text-slate-500">Gewicht {{ (item[2] * 100)|number_format(0) }}%</p>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        <h3 class="mt-5 text-sm font-semibold text-slate-950">Execution Layer</h3>
        <div class="mt-3 grid gap-3 md:grid-cols-3">
            {% for item in executionItems %}
                <div class="rounded-md border border-slate-200 p-3">
                    <div class="flex items-center justify-between gap-3">
                        <p class="text-sm font-medium text-slate-700 underline decoration-dotted underline-offset-4" title="{{ item[4] }}">{{ item[0] }}</p>
                        <p class="text-sm font-semibold text-slate-950">{{ item[1]|number_format(1) }}</p>
                    </div>
                    <div class="mt-2 h-2 rounded-full bg-slate-100">
                        <div class="h-2 rounded-full bg-sky-500" style="width: {{ item[1] }}%"></div>
                    </div>
                    {% if item[2] is not null %}
                        <p class="mt-1 text-xs text-slate-500">Execution-Gewicht {{ (item[2] * 100)|number_format(0) }}%</p>
                    {% endif %}
                    {% if item[3].contraction_count is defined %}
                        <p class="mt-2 text-xs text-slate-500">{{ item[3].contraction_count }} Kontraktionen / Volatilitaet {{ item[3].volatility_contraction_ratio ?? '-' }}</p>
                    {% elseif item[3].green_days_25d is defined %}
                        <p class="mt-2 text-xs text-slate-500">{{ item[3].green_days_25d }} gruen / {{ item[3].red_days_25d }} rot, U/D {{ item[3].up_down_volume_ratio_25d ?? '-' }}</p>
                    {% elseif item[3].setup_phase is defined %}
                        <p class="mt-2 text-xs text-slate-500">{{ item[3].setup_phase|replace({'_': ' '}) }} / Pivot {{ item[3].distance_to_pivot_pct ?? '-' }}%</p>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        <div class="mt-5 grid gap-4 lg:grid-cols-2">
            <div class="rounded-md bg-slate-50 p-4">
                {% set hardTriggers = detail.hard_trigger_summaries is defined ? detail.hard_trigger_summaries : sepaSnapshot.killTriggersJson %}
                {% set softWarnings = detail.soft_warning_summaries is defined ? detail.soft_warning_summaries : [] %}
                <h3 class="text-sm font-semibold text-slate-950">Trigger & Warnungen</h3>
                {% if hardTriggers is empty %}
                    <p class="mt-2 text-sm text-emerald-800">Keine harten Kill Trigger aktiv.</p>
                {% else %}
                    <ul class="mt-2 space-y-1 text-sm text-rose-800">
                        {% for trigger in hardTriggers %}
                            <li class="rounded-md bg-white px-2 py-1 ring-1 ring-rose-100" title="{{ trigger.triggers is defined ? trigger.triggers|join(', ') : '' }}">{{ trigger.label ?? trigger|replace({'_': ' '}) }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
                {% if softWarnings is not empty %}
                    <p class="mt-3 text-xs font-semibold uppercase text-amber-700">Soft Warnings / Execution Flaws</p>
                    <ul class="mt-2 space-y-1 text-sm text-amber-800">
                        {% for warning in softWarnings %}
                            <li class="rounded-md bg-white px-2 py-1 ring-1 ring-amber-100" title="{{ warning.triggers is defined ? warning.triggers|join(', ') : '' }}">{{ warning.label ?? warning|replace({'_': ' '}) }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
            <div class="rounded-md bg-slate-50 p-4">
                <h3 class="text-sm font-semibold text-slate-950">Einordnung</h3>
                <p class="mt-2 text-sm text-slate-700">
                    Specific Entry Point Analysis bewertet die strukturelle Setup-Qualitaet getrennt vom kurzfristigen Kronos-/Sentiment-Lauf.
                    Der Execution Layer ergaenzt VCP, Mikrostruktur und Breakout-Readiness. Die Ampel kombiniert Strukturqualitaet, Setup-Timing und Warnsignale.
                </p>
                {% if detail.traffic_light_reason is defined %}
                    <p class="mt-2 text-xs text-slate-500">Ampelgrund: {{ detail.traffic_light_reason|replace({'_': ' '}) }}.</p>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="mt-4 rounded-md border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-600">
            Noch kein Specific Entry Point Analysis Snapshot vorhanden. Starte den Python-Job `python stock-system/scripts/run_sepa.py --mode=db --source=portfolio`.
        </div>
    {% endif %}
</section>
