{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <p class="text-sm font-medium uppercase text-slate-500">{{ pageEyebrow }}</p>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">{{ pageTitle }}</h1>
            <p class="mt-1 text-sm text-slate-600">Standardmäßig werden nur aktive Instrumente angezeigt. Inaktive Werte bleiben erhalten und können separat reaktiviert werden.</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" href="{{ path('app_instruments_inactive') }}">Inaktive anzeigen</a>
            {% if showCreateButton %}
                <a class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm ring-1 ring-emerald-700/20 hover:bg-emerald-500" href="{{ path('app_instrument_new') }}">Instrument anlegen</a>
            {% endif %}
        </div>
    </div>

    <section class="overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ticker</th>
                    <th>Provider</th>
                    <th>Name</th>
                    <th>WKN</th>
                    <th>Asset</th>
                    <th>Region</th>
                    {% if showPortfolioColumn %}<th>Portfolio</th>{% endif %}
                    {% if showActiveColumn %}<th>Aktiv</th>{% endif %}
                    <th></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for instrument in instruments %}
                    <tr class="hover:bg-slate-50">
                        <td class="font-medium text-slate-950">{{ instrument.inputTicker }}</td>
                        <td>{{ instrument.providerTicker }}</td>
                        <td>{{ instrument.name ?: '-' }}</td>
                        <td>{{ instrument.wkn ?: '-' }}</td>
                        <td>{{ instrument.assetClass }}</td>
                        <td>{{ instrument.region ?: '-' }}</td>
                        {% if showPortfolioColumn %}
                            <td>
                                <form method="post" action="{{ path('app_instrument_toggle_portfolio', {id: instrument.id}) }}">
                                    <input type="hidden" name="return_route" value="{{ returnRoute }}">
                                    <label class="inline-flex items-center gap-2 text-xs font-medium text-slate-600">
                                        <input class="h-4 w-4 rounded border-slate-300 text-emerald-600" type="checkbox" {{ instrument.portfolio ? 'checked' : '' }} onchange="this.form.requestSubmit()">
                                        <span>{{ instrument.portfolio ? 'Portfolio' : 'Watchlist' }}</span>
                                    </label>
                                </form>
                            </td>
                        {% endif %}
                        {% if showActiveColumn %}
                            <td>
                                <form method="post" action="{{ path('app_instrument_toggle_active', {id: instrument.id}) }}">
                                    <input type="hidden" name="return_route" value="{{ returnRoute }}">
                                    <label class="inline-flex items-center gap-2 text-xs font-medium text-slate-600">
                                        <input class="h-4 w-4 rounded border-slate-300 text-emerald-600" type="checkbox" {{ instrument.active ? 'checked' : '' }} onchange="this.form.requestSubmit()">
                                        <span>{{ instrument.active ? 'Aktiv' : 'Inaktiv' }}</span>
                                    </label>
                                </form>
                            </td>
                        {% endif %}
                        <td class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a class="font-medium text-slate-950 underline decoration-slate-300 underline-offset-4 hover:decoration-slate-900" href="{{ path('app_instrument_show', {id: instrument.id}) }}">Details</a>
                                {% if returnRoute in ['app_portfolio_index', 'app_watchlist_index'] %}
                                    <form method="post" action="{{ path('app_instrument_delete', {id: instrument.id}) }}" onsubmit="return confirm('Instrument {{ instrument.inputTicker }} endgueltig loeschen?');">
                                        <input type="hidden" name="return_route" value="{{ returnRoute }}">
                                        <button class="rounded-md border border-rose-200 px-2 py-1 text-[11px] font-medium text-rose-700 hover:bg-rose-50" title="Instrument endgueltig loeschen. Abhaengige Runs und Snapshots werden per Cascade entfernt.">Loeschen</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td class="px-4 py-6 text-center text-slate-500" colspan="9">{{ emptyMessage }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
