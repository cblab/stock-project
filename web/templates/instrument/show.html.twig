{% extends 'base.html.twig' %}

{% block title %}{{ instrument.inputTicker }}{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <a class="text-sm text-slate-500 hover:text-slate-950" href="{{ path(instrument.portfolio ? 'app_portfolio_index' : 'app_watchlist_index') }}">Zurück zu {{ instrument.portfolio ? 'Portfolio' : 'Watchlist' }}</a>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">{{ instrument.displayTicker }}</h1>
            <p class="mt-1 text-sm text-slate-600">{{ instrument.name ?: 'Kein Name gepflegt' }}{% if instrument.wkn %} | WKN {{ instrument.wkn }}{% endif %}</p>
        </div>
        <div class="flex gap-2">
            <a class="rounded-md bg-slate-950 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" href="{{ path('app_instrument_edit', {id: instrument.id}) }}">Bearbeiten</a>
        </div>
    </div>

    <div class="mb-6">
        {% include '_last_run_snapshot.html.twig' with {
            lastRunItem: lastRunItem,
            showTickerLink: true,
            showInstrumentLink: false
        } only %}
    </div>

    <div class="mb-6">
        {% include 'instrument/_sepa_snapshot.html.twig' with {sepaSnapshot: sepaSnapshot} only %}
    </div>

    <div class="mb-6">
        {% include 'instrument/_epa_snapshot.html.twig' with {epaSnapshot: epaSnapshot} only %}
    </div>

    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <dl class="grid gap-4 text-sm md:grid-cols-3">
            <div><dt class="text-slate-500">Input Ticker</dt><dd class="font-medium">{{ instrument.inputTicker }}</dd></div>
            <div><dt class="text-slate-500">Provider Ticker</dt><dd class="font-medium">{{ instrument.providerTicker }}</dd></div>
            <div><dt class="text-slate-500">Display Ticker</dt><dd class="font-medium">{{ instrument.displayTicker }}</dd></div>
            <div><dt class="text-slate-500">Asset Class</dt><dd class="font-medium">{{ instrument.assetClass }}</dd></div>
            <div><dt class="text-slate-500">Region</dt><dd class="font-medium">{{ instrument.region ?: '-' }}</dd></div>
            <div><dt class="text-slate-500">Benchmark</dt><dd class="font-medium">{{ instrument.benchmark ?: '-' }}</dd></div>
            <div><dt class="text-slate-500">Portfolio</dt><dd class="font-medium">{{ instrument.portfolio ? 'Ja' : 'Nein' }}</dd></div>
            <div><dt class="text-slate-500">Aktiv</dt><dd class="font-medium">{{ instrument.active ? 'Ja' : 'Nein' }}</dd></div>
            <div><dt class="text-slate-500">Mapping Status</dt><dd class="font-medium">{{ instrument.mappingStatus ?: '-' }}</dd></div>
        </dl>
        {% if instrument.assetClass == 'ETF' %}
            <div class="mt-6 grid gap-4 text-sm md:grid-cols-2">
                <div><p class="text-slate-500">Region Exposure</p><p class="font-medium">{{ instrument.regionExposure|join(', ') ?: '-' }}</p></div>
                <div><p class="text-slate-500">Sector Profile</p><p class="font-medium">{{ instrument.sectorProfile|join(', ') ?: '-' }}</p></div>
                <div><p class="text-slate-500">Top Holdings</p><p class="font-medium">{{ instrument.topHoldingsProfile|join(', ') ?: '-' }}</p></div>
                <div><p class="text-slate-500">Macro Profile</p><p class="font-medium">{{ instrument.macroProfile|join(', ') ?: '-' }}</p></div>
            </div>
        {% endif %}
        {% if instrument.mappingNote %}
            <p class="mt-6 rounded-md bg-slate-50 p-3 text-sm text-slate-700">{{ instrument.mappingNote }}</p>
        {% endif %}
    </section>

    {% if open_campaigns is defined and open_campaigns is not empty %}
        {% set campaign = open_campaigns[0] %}
        {% set isPaused = campaign.state == 'paused' %}
        <section class="mt-6 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-950">Trade Management</h2>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">{{ campaign.trade_type|upper }} | {{ campaign.state|upper }}</span>
            </div>
            <div class="flex flex-wrap gap-2">
                {% if not isPaused %}
                    <button type="button" class="rounded-md bg-amber-600 px-3 py-2 text-sm font-medium text-white hover:bg-amber-500" onclick="document.getElementById('trim-modal').classList.remove('hidden')">Trim</button>
                    <button type="button" class="rounded-md bg-rose-600 px-3 py-2 text-sm font-medium text-white hover:bg-rose-500" onclick="document.getElementById('exit-modal').classList.remove('hidden')">Exit</button>
                    <button type="button" class="rounded-md bg-slate-600 px-3 py-2 text-sm font-medium text-white hover:bg-slate-500" onclick="document.getElementById('pause-modal').classList.remove('hidden')">Pause</button>
                {% else %}
                    <button type="button" class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500" onclick="document.getElementById('resume-modal').classList.remove('hidden')">Resume</button>
                    <button type="button" class="rounded-md bg-rose-600 px-3 py-2 text-sm font-medium text-white hover:bg-rose-500" onclick="document.getElementById('exit-modal').classList.remove('hidden')">Exit</button>
                {% endif %}
            </div>
        </section>

        {# Trim Modal #}
        <div id="trim-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="w-full max-w-lg rounded-lg bg-white p-6 shadow-lg max-h-[90vh] overflow-y-auto">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-slate-950">Trim Position</h2>
                    <button type="button" class="text-slate-400 hover:text-slate-600" onclick="document.getElementById('trim-modal').classList.add('hidden')">&times;</button>
                </div>
                <form method="post" action="{{ path('app_trade_event_create', {id: campaign.id}) }}">
                    <input type="hidden" name="return_route" value="app_instrument_show">
                    <input type="hidden" name="event_type" value="trim">
                    <input type="hidden" name="_token" value="{{ csrf_token('trade_event_' ~ campaign.id) }}">
                    <div class="grid gap-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Preis *</label>
                                <input type="number" step="0.0001" name="event_price" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Menge *</label>
                                <input type="number" step="0.0001" name="quantity" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Exit-Grund *</label>
                            <select name="exit_reason" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                                <option value="">Bitte wählen</option>
                                <option value="signal">Signal</option>
                                <option value="stop_loss">Stop-Loss</option>
                                <option value="trailing_stop">Trailing Stop</option>
                                <option value="time_based">Zeitbasiert</option>
                                <option value="rebalance">Rebalancing</option>
                                <option value="opportunity_cost">Opportunitätskosten</option>
                                <option value="macro_regime_change">Makro-Regime-Wechsel</option>
                                <option value="thesis_invalidated">These invalidiert</option>
                                <option value="manual">Manuell</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Zeitstempel *</label>
                            <input type="datetime-local" name="event_timestamp" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Notizen</label>
                            <textarea name="event_notes" rows="2" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end gap-2">
                        <button type="button" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" onclick="document.getElementById('trim-modal').classList.add('hidden')">Abbrechen</button>
                        <button type="submit" class="rounded-md bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-500">Speichern</button>
                    </div>
                </form>
            </div>
        </div>

        {# Exit Modal (hard_exit / return_to_watchlist) #}
        <div id="exit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="w-full max-w-lg rounded-lg bg-white p-6 shadow-lg max-h-[90vh] overflow-y-auto">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-slate-950">Position Schließen</h2>
                    <button type="button" class="text-slate-400 hover:text-slate-600" onclick="document.getElementById('exit-modal').classList.add('hidden')">&times;</button>
                </div>
                <form method="post" action="{{ path('app_trade_event_create', {id: campaign.id}) }}" id="exit-form">
                    <input type="hidden" name="return_route" value="app_instrument_show">
                    <input type="hidden" name="_token" value="{{ csrf_token('trade_event_' ~ campaign.id) }}">
                    <div class="mb-4 flex gap-4">
                        <label class="flex items-center gap-2">
                            <input type="radio" name="event_type" value="hard_exit" checked onchange="updateExitLabel()">
                            <span class="text-sm font-medium">Hard Exit</span>
                        </label>
                        <label class="flex items-center gap-2">
                            <input type="radio" name="event_type" value="return_to_watchlist" onchange="updateExitLabel()">
                            <span class="text-sm font-medium">Zurück zur Watchlist</span>
                        </label>
                    </div>
                    <div class="grid gap-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Preis *</label>
                                <input type="number" step="0.0001" name="event_price" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Menge (optional)</label>
                                <input type="number" step="0.0001" name="quantity" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Exit-Grund *</label>
                            <select name="exit_reason" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                                <option value="">Bitte wählen</option>
                                <option value="signal">Signal</option>
                                <option value="stop_loss">Stop-Loss</option>
                                <option value="trailing_stop">Trailing Stop</option>
                                <option value="time_based">Zeitbasiert</option>
                                <option value="rebalance">Rebalancing</option>
                                <option value="opportunity_cost">Opportunitätskosten</option>
                                <option value="macro_regime_change">Makro-Regime-Wechsel</option>
                                <option value="thesis_invalidated">These invalidiert</option>
                                <option value="manual">Manuell</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Zeitstempel *</label>
                            <input type="datetime-local" name="event_timestamp" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Notizen</label>
                            <textarea name="event_notes" rows="2" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end gap-2">
                        <button type="button" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" onclick="document.getElementById('exit-modal').classList.add('hidden')">Abbrechen</button>
                        <button type="submit" class="rounded-md bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-500">Position schließen</button>
                    </div>
                </form>
            </div>
        </div>

        {# Pause Modal #}
        <div id="pause-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-lg">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-slate-950">Trade pausieren</h2>
                    <button type="button" class="text-slate-400 hover:text-slate-600" onclick="document.getElementById('pause-modal').classList.add('hidden')">&times;</button>
                </div>
                <form method="post" action="{{ path('app_trade_event_create', {id: campaign.id}) }}">
                    <input type="hidden" name="return_route" value="app_instrument_show">
                    <input type="hidden" name="event_type" value="pause">
                    <input type="hidden" name="_token" value="{{ csrf_token('trade_event_' ~ campaign.id) }}">
                    <div class="grid gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Zeitstempel *</label>
                            <input type="datetime-local" name="event_timestamp" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Notizen</label>
                            <textarea name="event_notes" rows="2" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end gap-2">
                        <button type="button" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" onclick="document.getElementById('pause-modal').classList.add('hidden')">Abbrechen</button>
                        <button type="submit" class="rounded-md bg-slate-600 px-4 py-2 text-sm font-medium text-white hover:bg-slate-500">Pausieren</button>
                    </div>
                </form>
            </div>
        </div>

        {# Resume Modal #}
        <div id="resume-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-lg">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-slate-950">Trade fortsetzen</h2>
                    <button type="button" class="text-slate-400 hover:text-slate-600" onclick="document.getElementById('resume-modal').classList.add('hidden')">&times;</button>
                </div>
                <form method="post" action="{{ path('app_trade_event_create', {id: campaign.id}) }}">
                    <input type="hidden" name="return_route" value="app_instrument_show">
                    <input type="hidden" name="event_type" value="resume">
                    <input type="hidden" name="_token" value="{{ csrf_token('trade_event_' ~ campaign.id) }}">
                    <div class="grid gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Zeitstempel *</label>
                            <input type="datetime-local" name="event_timestamp" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Notizen</label>
                            <textarea name="event_notes" rows="2" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end gap-2">
                        <button type="button" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" onclick="document.getElementById('resume-modal').classList.add('hidden')">Abbrechen</button>
                        <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500">Fortsetzen</button>
                    </div>
                </form>
            </div>
        </div>
    {% endif %}
{% endblock %}