{% extends 'base.html.twig' %}
{% import 'dashboard/_ui.html.twig' as ui %}

{% block title %}{{ instrument.inputTicker }}{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <a class="text-sm text-slate-500 hover:text-slate-950" href="{{ path(instrument.portfolio ? 'app_portfolio_index' : 'app_watchlist_index') }}">Zurueck zu {{ instrument.portfolio ? 'Portfolio' : 'Watchlist' }}</a>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">{{ instrument.displayTicker }}</h1>
            <p class="mt-1 text-sm text-slate-600">{{ instrument.name ?: 'Kein Name gepflegt' }}{% if instrument.wkn %} | WKN {{ instrument.wkn }}{% endif %}</p>
        </div>
        <a class="rounded-md bg-slate-950 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" href="{{ path('app_instrument_edit', {id: instrument.id}) }}">Bearbeiten</a>
    </div>

    <div class="mb-6">
        {% include '_last_run_snapshot.html.twig' with {
            lastRunItem: lastRunItem,
            showTickerLink: true,
            showInstrumentLink: false
        } only %}
    </div>

    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <dl class="grid gap-4 text-sm md:grid-cols-3">
            <div><dt class="text-slate-500">Input Ticker</dt><dd class="font-medium">{{ instrument.inputTicker }}</dd></div>
            <div><dt class="text-slate-500">Provider Ticker</dt><dd class="font-medium">{{ instrument.providerTicker }}</dd></div>
            <div><dt class="text-slate-500">Display Ticker</dt><dd class="font-medium">{{ instrument.displayTicker }}</dd></div>
            <div><dt class="text-slate-500">Asset Class</dt><dd class="font-medium">{{ instrument.assetClass }}</dd></div>
            <div><dt class="text-slate-500">Region</dt><dd class="font-medium">{{ instrument.region ?: '-' }}</dd></div>
            <div><dt class="text-slate-500">Benchmark</dt><dd class="font-medium">{{ instrument.benchmark ?: '-' }}</dd></div>
            <div><dt class="text-slate-500">Portfolio</dt><dd class="font-medium">{{ instrument.portfolio ? 'Ja' : 'Nein' }}</dd></div>
            <div><dt class="text-slate-500">Aktiv</dt><dd class="font-medium">{{ instrument.active ? 'Ja' : 'Nein' }}</dd></div>
            <div><dt class="text-slate-500">Mapping Status</dt><dd class="font-medium">{{ instrument.mappingStatus ?: '-' }}</dd></div>
        </dl>
        {% if instrument.assetClass == 'ETF' %}
            <div class="mt-6 grid gap-4 text-sm md:grid-cols-2">
                <div><p class="text-slate-500">Region Exposure</p><p class="font-medium">{{ instrument.regionExposure|join(', ') ?: '-' }}</p></div>
                <div><p class="text-slate-500">Sector Profile</p><p class="font-medium">{{ instrument.sectorProfile|join(', ') ?: '-' }}</p></div>
                <div><p class="text-slate-500">Top Holdings</p><p class="font-medium">{{ instrument.topHoldingsProfile|join(', ') ?: '-' }}</p></div>
                <div><p class="text-slate-500">Macro Profile</p><p class="font-medium">{{ instrument.macroProfile|join(', ') ?: '-' }}</p></div>
            </div>
        {% endif %}
        {% if instrument.mappingNote %}
            <p class="mt-6 rounded-md bg-slate-50 p-3 text-sm text-slate-700">{{ instrument.mappingNote }}</p>
        {% endif %}
    </section>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Letzter Lauf</h2>
            {% if lastRunItem %}
                <a class="text-sm font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 hover:text-slate-950 hover:decoration-slate-900" href="{{ path('app_run_show', {id: lastRunItem.pipelineRun.id}) }}">Run oeffnen</a>
            {% endif %}
        </div>

        {% if lastRunItem %}
            {% set runScope = lastRunItem.instrument.portfolio ? 'Portfolio' : 'Watchlist' %}
            <div class="mt-3 flex flex-wrap gap-2">
                {{ ui.decision_badge(lastRunItem.decision) }}
                <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200">{{ runScope }}</span>
                <span class="rounded-full bg-white px-2 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200">{{ lastRunItem.sentimentLabel ?: 'sentiment n/a' }}</span>
                {{ ui.status_badge(lastRunItem.marketDataStatus) }}
                {{ ui.status_badge(lastRunItem.newsStatus) }}
            </div>

            <dl class="mt-4 grid gap-3 text-sm md:grid-cols-2 lg:grid-cols-3">
                <div>
                    <dt class="text-slate-500">Run-Zeit</dt>
                    <dd class="font-medium text-slate-900">{{ (lastRunItem.pipelineRun.startedAt ?: lastRunItem.pipelineRun.createdAt)|date('d.m.Y H:i') }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Run-ID</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.pipelineRun.runId }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Sentiment Mode</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.sentimentMode ?: '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">K Norm</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.kronosNormalizedScore is not null ? lastRunItem.kronosNormalizedScore|number_format(2) : '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">S Norm</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.sentimentNormalizedScore is not null ? lastRunItem.sentimentNormalizedScore|number_format(2) : '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Merged</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.mergedScore is not null ? lastRunItem.mergedScore|number_format(2) : '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Decision</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.decision }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Sentiment Label</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.sentimentLabel ?: '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Data / News</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.marketDataStatus ?: '-' }} / {{ lastRunItem.newsStatus ?: '-' }}</dd>
                </div>
            </dl>

            <div class="mt-4 flex flex-wrap gap-4 text-sm">
                <a class="font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 hover:text-slate-950 hover:decoration-slate-900" href="{{ path('app_run_show', {id: lastRunItem.pipelineRun.id}) }}">Run oeffnen</a>
                <a class="font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 hover:text-slate-950 hover:decoration-slate-900" href="{{ path('app_ticker_show', {id: lastRunItem.id}) }}">Ticker im Run oeffnen</a>
            </div>
        {% else %}
            <p class="mt-3 text-sm text-slate-600">Noch kein Lauf vorhanden.</p>
        {% endif %}
    </section>
{% endblock %}
