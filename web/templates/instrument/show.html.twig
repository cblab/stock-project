{% extends 'base.html.twig' %}

{% block title %}{{ instrument.inputTicker }}{% endblock %}
{% block page_title %}{{ instrument.displayTicker }}{% endblock %}

{% block body %}
    {# Preserve-refactor: new visual shell, existing truth-layer blocks and trade forms retained. #}

    <section class="panel-card mb-6">
        <div class="px-6 py-5">
            <div class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
                <div class="min-w-0">
                    <a class="text-sm font-medium text-surface-500 hover:text-surface-900" href="{{ path(instrument.portfolio ? 'app_portfolio_index' : 'app_watchlist_index') }}">
                        ← Zurück zu {{ instrument.portfolio ? 'Portfolio' : 'Watchlist' }}
                    </a>

                    <div class="mt-3 flex flex-wrap items-center gap-2">
                        <h1 class="text-3xl font-bold tracking-tight text-surface-900">{{ instrument.displayTicker }}</h1>

                        {% if instrument.portfolio %}
                            <span class="compact-badge bg-primary-50 text-primary-700 ring-primary-600/20">Portfolio</span>
                        {% else %}
                            <span class="compact-badge bg-surface-100 text-surface-600 ring-surface-300">Watchlist</span>
                        {% endif %}

                        {% if instrument.active %}
                            <span class="compact-badge bg-surface-100 text-surface-700 ring-surface-300">Aktiv</span>
                        {% else %}
                            <span class="compact-badge bg-danger-50 text-danger-700 ring-danger-600/20">Inaktiv</span>
                        {% endif %}

                        {% if instrument.mappingStatus %}
                            <span class="compact-badge bg-accent-50 text-accent-700 ring-accent-600/20">{{ instrument.mappingStatus }}</span>
                        {% endif %}

                        {% if instrument.portfolio and open_campaigns is defined and open_campaigns|length > 0 %}
                            <span class="compact-badge bg-accent-50 text-accent-700 ring-accent-600/20">Offene Campaign</span>
                        {% endif %}
                    </div>

                    <p class="mt-2 text-base text-surface-600">
                        {{ instrument.name ?: 'Kein Name gepflegt' }}
                        {% if instrument.wkn %}<span class="text-surface-400"> · WKN {{ instrument.wkn }}</span>{% endif %}
                        {% if instrument.isin %}<span class="text-surface-400"> · ISIN {{ instrument.isin }}</span>{% endif %}
                    </p>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    {% if not instrument.portfolio %}
                        <button type="button" class="btn-primary" onclick="document.getElementById('entry-modal').classList.remove('hidden')">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                            Zu Portfolio hinzufügen
                        </button>
                    {% endif %}

                    {% if instrument.portfolio and open_campaigns is defined and open_campaigns|length > 0 %}
                        <button type="button" class="btn-accent" onclick="document.getElementById('event-modal').classList.remove('hidden')">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8m-4-4h8"/>
                            </svg>
                            Trade Event
                        </button>
                    {% endif %}

                    <a href="{{ path('app_instrument_edit', {id: instrument.id}) }}" class="btn-secondary">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Bearbeiten
                    </a>
                </div>
            </div>
        </div>
    </section>

    {# Executive Summary only. Full diagnostic truth remains in the existing includes below. #}
    <section class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="metric-card">
            <p class="text-xs font-medium uppercase tracking-wider text-surface-500">SEPA</p>
            <div class="mt-2 flex items-baseline justify-between gap-3">
                <p class="text-3xl font-bold text-surface-900">
                    {% if sepaSnapshot %}{{ sepaSnapshot.totalScore|number_format(1, '.', '') }}{% else %}–{% endif %}
                </p>
                {% if sepaSnapshot %}
                    <span class="compact-badge {{ sepaSnapshot.trafficLight == 'Grün' ? 'bg-primary-50 text-primary-700 ring-primary-600/20' : sepaSnapshot.trafficLight == 'Gelb' ? 'bg-accent-50 text-accent-700 ring-accent-600/20' : 'bg-danger-50 text-danger-700 ring-danger-600/20' }}">
                        {{ sepaSnapshot.trafficLight }}
                    </span>
                {% endif %}
            </div>
            <p class="mt-1 text-xs text-surface-500">
                {% if sepaSnapshot %}{{ sepaSnapshot.asOfDate|date('d.m.Y') }}{% else %}Kein SEPA Snapshot{% endif %}
            </p>
        </div>

        <div class="metric-card">
            <p class="text-xs font-medium uppercase tracking-wider text-surface-500">EPA</p>
            <div class="mt-2 flex items-baseline justify-between gap-3">
                <p class="text-3xl font-bold text-surface-900">
                    {% if epaSnapshot %}{{ epaSnapshot.totalScore|number_format(1, '.', '') }}{% else %}–{% endif %}
                </p>
                {% if epaSnapshot %}
                    <span class="compact-badge {{ epaSnapshot.action in ['HARD_EXIT', 'EXIT'] ? 'bg-danger-50 text-danger-700 ring-danger-600/20' : epaSnapshot.action in ['TRIM', 'TIGHTEN_RISK'] ? 'bg-accent-50 text-accent-700 ring-accent-600/20' : 'bg-primary-50 text-primary-700 ring-primary-600/20' }}">
                        {{ epaSnapshot.action }}
                    </span>
                {% endif %}
            </div>
            <p class="mt-1 text-xs text-surface-500">
                {% if epaSnapshot %}{{ epaSnapshot.asOfDate|date('d.m.Y') }}{% else %}Kein EPA Snapshot{% endif %}
            </p>
        </div>

        <div class="metric-card">
            <p class="text-xs font-medium uppercase tracking-wider text-surface-500">Last Run</p>
            <div class="mt-2 flex items-baseline justify-between gap-3">
                <p class="text-3xl font-bold text-surface-900">
                    {% if lastRunItem and lastRunItem.mergedScore is not null %}{{ lastRunItem.mergedScore|number_format(3, '.', '') }}{% else %}–{% endif %}
                </p>
                {% if lastRunItem %}
                    <span class="compact-badge bg-surface-100 text-surface-700 ring-surface-300">{{ lastRunItem.decision }}</span>
                {% endif %}
            </div>
            <p class="mt-1 text-xs text-surface-500">
                {% if lastRunItem %}Merged / Decision{% else %}Kein Run Item{% endif %}
            </p>
        </div>

        <div class="metric-card">
            <p class="text-xs font-medium uppercase tracking-wider text-surface-500">Sentiment</p>
            <div class="mt-2 flex items-baseline justify-between gap-3">
                <p class="truncate text-2xl font-bold text-surface-900">
                    {% if lastRunItem and lastRunItem.sentimentLabel %}{{ lastRunItem.sentimentLabel }}{% else %}–{% endif %}
                </p>
                {% if lastRunItem and lastRunItem.sentimentNormalizedScore is not null %}
                    <span class="compact-badge bg-surface-100 text-surface-700 ring-surface-300">{{ lastRunItem.sentimentNormalizedScore|number_format(3, '.', '') }}</span>
                {% endif %}
            </div>
            <p class="mt-1 text-xs text-surface-500">
                {% if lastRunItem and lastRunItem.sentimentMode %}{{ lastRunItem.sentimentMode }}{% else %}Sentiment Mode{% endif %}
            </p>
        </div>
    </section>

    {# Truth layer diagnostics: keep full information density. Do not replace with KPI-only cards. #}
    <section class="mb-6">
        <div class="mb-3 flex items-center justify-between">
            <div>
                <h2 class="text-lg font-semibold tracking-tight text-surface-900">Diagnose & Signal-Wahrheit</h2>
                <p class="text-sm text-surface-500">Last Run, SEPA und EPA bleiben vollständig erhalten: Scores, Bänder, Gewichte, Trigger und Warnungen.</p>
            </div>
        </div>

        <div class="space-y-6">
            {% include '_last_run_snapshot.html.twig' with {
                lastRunItem: lastRunItem,
                showTickerLink: true,
                showInstrumentLink: false
            } only %}

            {% include 'instrument/_sepa_snapshot.html.twig' with {sepaSnapshot: sepaSnapshot} only %}

            {% include 'instrument/_epa_snapshot.html.twig' with {epaSnapshot: epaSnapshot} only %}
        </div>
    </section>

    <section class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="lg:col-span-1">
            <div class="panel-card">
                <div class="border-b border-surface-100 px-6 py-4">
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-900">Stammdaten</h3>
                </div>
                <div class="divide-y divide-surface-100">
                    <div class="flex items-center justify-between gap-4 px-6 py-3">
                        <span class="text-sm text-surface-500">Input Ticker</span>
                        <span class="font-mono text-sm font-medium text-surface-900">{{ instrument.inputTicker }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-6 py-3">
                        <span class="text-sm text-surface-500">Provider Ticker</span>
                        <span class="font-mono text-sm font-medium text-surface-900">{{ instrument.providerTicker }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-6 py-3">
                        <span class="text-sm text-surface-500">Display Ticker</span>
                        <span class="font-mono text-sm font-medium text-surface-900">{{ instrument.displayTicker }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-6 py-3">
                        <span class="text-sm text-surface-500">Asset Class</span>
                        <span class="text-sm font-medium text-surface-900">{{ instrument.assetClass ?: '–' }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-6 py-3">
                        <span class="text-sm text-surface-500">Region</span>
                        <span class="text-sm font-medium text-surface-900">{{ instrument.region ?: '–' }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-6 py-3">
                        <span class="text-sm text-surface-500">Benchmark</span>
                        <span class="text-right text-sm font-medium text-surface-900">{{ instrument.benchmark ?: '–' }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-6 py-3">
                        <span class="text-sm text-surface-500">Mapping Status</span>
                        <span class="text-sm font-medium text-surface-900">{{ instrument.mappingStatus ?: '–' }}</span>
                    </div>
                    {% if instrument.contextType %}
                        <div class="flex items-center justify-between gap-4 px-6 py-3">
                            <span class="text-sm text-surface-500">Context Type</span>
                            <span class="text-sm font-medium text-surface-900">{{ instrument.contextType }}</span>
                        </div>
                    {% endif %}
                </div>
                {% if instrument.mappingNote %}
                    <div class="border-t border-surface-100 px-6 py-4">
                        <p class="text-xs font-medium uppercase tracking-wider text-surface-500">Mapping Note</p>
                        <p class="mt-2 rounded-lg bg-surface-50 p-3 text-sm text-surface-700">{{ instrument.mappingNote }}</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="space-y-4 lg:col-span-2">
            <div class="panel-card">
                <div class="flex items-center justify-between border-b border-surface-100 px-6 py-4">
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-900">Region Exposure</h3>
                    {% if instrument.regionExposure|length > 0 %}
                        <span class="compact-badge bg-surface-100 text-surface-600 ring-surface-300">{{ instrument.regionExposure|length }}</span>
                    {% endif %}
                </div>
                <div class="px-6 py-4">
                    {% if instrument.regionExposure|length > 0 %}
                        <div class="flex flex-wrap gap-2">
                            {% for region in instrument.regionExposure %}
                                <span class="inline-flex items-center rounded-lg bg-surface-100 px-3 py-1.5 text-sm font-medium text-surface-700">{{ region }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm italic text-surface-400">Keine Regionen hinterlegt.</p>
                    {% endif %}
                </div>
            </div>

            <div class="panel-card">
                <div class="flex items-center justify-between border-b border-surface-100 px-6 py-4">
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-900">Sector Profile</h3>
                    {% if instrument.sectorProfile|length > 0 %}
                        <span class="compact-badge bg-surface-100 text-surface-600 ring-surface-300">{{ instrument.sectorProfile|length }}</span>
                    {% endif %}
                </div>
                <div class="px-6 py-4">
                    {% if instrument.sectorProfile|length > 0 %}
                        <div class="flex flex-wrap gap-2">
                            {% for sector in instrument.sectorProfile %}
                                <span class="inline-flex items-center rounded-lg bg-primary-50 px-3 py-1.5 text-sm font-medium text-primary-700">{{ sector }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm italic text-surface-400">Keine Sektoren hinterlegt.</p>
                    {% endif %}
                </div>
            </div>

            <div class="panel-card">
                <div class="flex items-center justify-between border-b border-surface-100 px-6 py-4">
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-900">Top Holdings</h3>
                    {% if instrument.topHoldingsProfile|length > 0 %}
                        <span class="compact-badge bg-surface-100 text-surface-600 ring-surface-300">{{ instrument.topHoldingsProfile|length }}</span>
                    {% endif %}
                </div>
                <div class="px-6 py-4">
                    {% if instrument.topHoldingsProfile|length > 0 %}
                        <div class="flex flex-wrap gap-2">
                            {% for holding in instrument.topHoldingsProfile %}
                                <span class="inline-flex items-center rounded-lg bg-accent-50 px-3 py-1.5 text-sm font-medium text-accent-700">{{ holding }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm italic text-surface-400">Keine Holdings hinterlegt.</p>
                    {% endif %}
                </div>
            </div>

            <div class="panel-card">
                <div class="flex items-center justify-between border-b border-surface-100 px-6 py-4">
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-900">Macro Profile</h3>
                    {% if instrument.macroProfile|length > 0 %}
                        <span class="compact-badge bg-surface-100 text-surface-600 ring-surface-300">{{ instrument.macroProfile|length }}</span>
                    {% endif %}
                </div>
                <div class="px-6 py-4">
                    {% if instrument.macroProfile|length > 0 %}
                        <div class="flex flex-wrap gap-2">
                            {% for macro in instrument.macroProfile %}
                                <span class="inline-flex items-center rounded-lg bg-danger-50 px-3 py-1.5 text-sm font-medium text-danger-700">{{ macro }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm italic text-surface-400">Kein Macro-Profil hinterlegt.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    {% if not instrument.portfolio %}
    {# Entry Modal: preserved from working v0.4 flow. #}
    <div id="entry-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
        <div class="w-full max-w-lg rounded-lg bg-white p-6 shadow-lg max-h-[90vh] overflow-y-auto">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-950">Entry: {{ instrument.displayTicker }}</h2>
                <button type="button" class="text-slate-400 hover:text-slate-600" onclick="document.getElementById('entry-modal').classList.add('hidden')">&times;</button>
            </div>
            <form method="post" action="{{ path('app_instrument_portfolio_entry', {id: instrument.id}) }}" data-turbo="false">
                <input type="hidden" name="return_route" value="{{ instrument.portfolio ? 'app_portfolio_index' : 'app_watchlist_index' }}">
                <input type="hidden" name="_token" value="{{ csrf_token('portfolio_entry_' ~ instrument.id) }}">
                <div class="grid gap-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Kaufpreis *</label>
                            <input type="number" step="0.0001" name="event_price" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Menge *</label>
                            <input type="number" step="0.0001" name="quantity" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Kaufdatum *</label>
                        <input type="datetime-local" name="event_timestamp" value="{{ 'now'|date('Y-m-d\\TH:i') }}" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                    </div>
                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Gebühren</label>
                            <input type="number" step="0.01" name="fees" value="0.00" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Währung</label>
                            <input type="text" name="currency" value="EUR" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Trade-Typ</label>
                            <select name="trade_type" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                                <option value="live" selected>Live</option>
                                <option value="paper">Paper</option>
                                <option value="pseudo">Pseudo</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Entry Thesis</label>
                        <textarea name="entry_thesis" rows="2" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Invalidierungsregel</label>
                        <input type="text" name="invalidation_rule" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Notizen</label>
                        <textarea name="event_notes" rows="2" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
                    </div>
                </div>
                <div class="mt-6 flex justify-end gap-2">
                    <button type="button" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" onclick="document.getElementById('entry-modal').classList.add('hidden')">Abbrechen</button>
                    <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500">Speichern</button>
                </div>
            </form>
        </div>
    </div>
    {% endif %}

    {% if instrument.portfolio and open_campaigns is defined and open_campaigns|length > 0 %}
    {# Trade Event Modal: preserved from working v0.4 flow. #}
    <div id="event-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
        <div class="w-full max-w-lg rounded-lg bg-white p-6 shadow-lg max-h-[90vh] overflow-y-auto">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-950">Trade Event: {{ instrument.displayTicker }}</h2>
                <button type="button" class="text-slate-400 hover:text-slate-600" onclick="document.getElementById('event-modal').classList.add('hidden')">&times;</button>
            </div>
            <form method="post" action="{{ path('app_trade_campaign_event', {id: open_campaigns[0].id}) }}" data-turbo="false">
                <input type="hidden" name="return_route" value="app_instrument_show">
                <input type="hidden" name="_token" value="{{ csrf_token('trade_event_' ~ open_campaigns[0].id) }}">
                <div class="grid gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Event-Typ *</label>
                        <select name="event_type" id="event_type" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onchange="updateEventFields()">
                            <option value="">-- Auswählen --</option>
                            <option value="trim">Teilverkauf (Trim)</option>
                            <option value="hard_exit">Komplettverkauf (Hard Exit)</option>
                            <option value="return_to_watchlist">Zurück zur Watchlist</option>
                            <option value="pause">Pausieren</option>
                            <option value="resume">Fortsetzen</option>
                            <option value="add">Nachkauf / Aufstocken</option>
                        </select>
                    </div>
                    <div id="price-field" class="hidden">
                        <label class="block text-sm font-medium text-slate-700">Preis *</label>
                        <input type="number" step="0.0001" name="event_price" id="event_price" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                    </div>
                    <div id="quantity-field" class="hidden">
                        <label class="block text-sm font-medium text-slate-700">
                            Menge <span id="quantity-hint" class="text-slate-500 font-normal">(leer = gesamte Position)</span>
                        </label>
                        <input type="number" step="0.0001" name="quantity" id="quantity" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                    </div>
                    <div id="exit-reason-field" class="hidden">
                        <label class="block text-sm font-medium text-slate-700">Exit-Grund *</label>
                        <select name="exit_reason" id="exit_reason" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                            <option value="">-- Auswählen --</option>
                            <option value="signal">Signal</option>
                            <option value="technical">Technisch</option>
                            <option value="fundamental">Fundamental</option>
                            <option value="risk">Risiko</option>
                            <option value="other">Sonstiges</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Zeitstempel *</label>
                        <input type="datetime-local" name="event_timestamp" required class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Gebühren</label>
                        <input type="number" step="0.01" name="fees" value="0.00" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Währung</label>
                        <input type="text" name="currency" value="EUR" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Notizen</label>
                        <textarea name="event_notes" rows="2" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
                    </div>
                </div>
                <div class="mt-4 flex gap-2">
                    <button type="submit" class="rounded-md bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-500">Speichern</button>
                    <button type="button" class="rounded-md bg-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-300" onclick="document.getElementById('event-modal').classList.add('hidden')">Abbrechen</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function updateEventFields() {
            const eventType = document.getElementById('event_type').value;
            const priceField = document.getElementById('price-field');
            const quantityField = document.getElementById('quantity-field');
            const exitReasonField = document.getElementById('exit-reason-field');
            const quantityInput = document.getElementById('quantity');

            document.getElementById('event_price').required = false;
            document.getElementById('exit_reason').required = false;
            quantityInput.required = false;

            if (eventType === 'trim') {
                priceField.classList.remove('hidden');
                quantityField.classList.remove('hidden');
                exitReasonField.classList.remove('hidden');
                document.getElementById('event_price').required = true;
                document.getElementById('exit_reason').required = true;
                quantityInput.required = true;
            } else if (eventType === 'hard_exit' || eventType === 'return_to_watchlist') {
                priceField.classList.remove('hidden');
                quantityField.classList.remove('hidden');
                exitReasonField.classList.remove('hidden');
                document.getElementById('event_price').required = true;
                document.getElementById('exit_reason').required = true;
                quantityInput.required = false;
            } else if (eventType === 'pause' || eventType === 'resume') {
                priceField.classList.add('hidden');
                quantityField.classList.add('hidden');
                exitReasonField.classList.add('hidden');
            } else if (eventType === 'add') {
                priceField.classList.remove('hidden');
                quantityField.classList.remove('hidden');
                exitReasonField.classList.add('hidden');
                document.getElementById('event_price').required = true;
                quantityInput.required = true;
            } else {
                priceField.classList.add('hidden');
                quantityField.classList.add('hidden');
                exitReasonField.classList.add('hidden');
            }
        }
    </script>
    {% endif %}
{% endblock %}
