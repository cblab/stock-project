{% extends 'base.html.twig' %}

{% macro sort_header(label, key, sort, pagination, showRejected, title) %}
    {% set active = sort.key == key %}
    {% set nextDir = active and sort.dir == 'asc' ? 'desc' : 'asc' %}
    <a class="inline-flex items-center gap-1 hover:text-slate-950" href="{{ path('app_watchlist_intake', {sort: key, dir: nextDir, page: 1, perPage: pagination.per_page, showRejected: showRejected ? 1 : 0}) }}" title="{{ title }}">
        <span>{{ label }}</span>
        <span class="text-[10px] {{ active ? 'text-slate-500' : 'text-slate-300' }}">{{ active ? (sort.dir == 'asc' ? '^' : 'v') : '<>' }}</span>
    </a>
{% endmacro %}

{% block title %}Watchlist Intake{% endblock %}

{% block body %}
    {% import _self as table %}
    <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <p class="text-sm font-medium uppercase text-slate-500">Sector Discovery & Watchlist Proposal System</p>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">Watchlist Candidate Registry</h1>
            <p class="mt-1 max-w-4xl text-sm text-slate-600">
                Das Modul identifiziert starke Sektoren, entdeckt Kandidaten dynamisch aus Sektor-ETF-Holdings und fuehrt sie kumulativ in einer deduplizierten Registry.
                Die Aufnahme erfolgt bewusst manuell. Specific Entry Point Analysis ist die primaere Bewertungslogik; Kronos und Sentiment ergaenzen nur als Kontext.
            </p>
        </div>
        {% if run %}
            <div class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm">
                <span class="font-medium text-slate-950">Letzter Lauf: {{ run.status }}</span>
                <span class="text-slate-500"> / Registry View</span>
            </div>
        {% endif %}
    </div>

    {% if run is null %}
        <section class="rounded-lg border border-dashed border-slate-300 bg-white p-5 text-sm text-slate-600">
            Noch kein Watchlist-Candidate-Registry-Lauf vorhanden. Starte `python stock-system/scripts/run_watchlist_intake.py --mode=db`.
        </section>
    {% else %}
        {% set diagnostics = run.summary.diagnostics ?? {} %}
        <section class="mb-5 grid gap-3 md:grid-cols-4">
            <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                <p class="text-xs uppercase text-slate-500">Run</p>
                <p class="mt-1 font-semibold text-slate-950">{{ run.run_key }}</p>
                <p class="text-xs text-slate-500">{{ run.created_at|date('d.m.Y H:i') }}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                <p class="text-xs uppercase text-slate-500" title="Nur die staerksten Sektoren werden weiter untersucht. Der Score kombiniert Sektor-Performance und relative Staerke gegen SPY.">Top-Sektoren</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950">{{ sectors|length }}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                <p class="text-xs uppercase text-slate-500" title="Kumulativer deduplizierter Kandidatenbestand ueber alle Intake-Laeufe.">Registry-Kandidaten</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950">{{ metrics.total_candidates }}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
                <p class="text-xs uppercase text-slate-500" title="Watchlist-Aufnahmen entstehen nur durch Nutzeraktion, nie durch den Python-Job.">Manuell aufgenommen</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950">{{ metrics.manually_added }}</p>
            </div>
        </section>

        <section class="mb-5 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
            <span class="font-medium text-slate-950">Letzter Lauf:</span>
            {{ diagnostics.excluded_active|default(0) }} wegen aktivem Portfolio-/Watchlist-Bestand ausgeschlossen,
            {{ diagnostics.cooldown_skipped|default(0) }} wegen Kandidaten-Cooldown pro Ticker uebersprungen,
            {{ diagnostics.eligible_after_exclusions|default(0) }} nach Ausschluessen im Kandidatenpool,
            {{ diagnostics.written_candidates|default(0) }} historische Lauf-Kandidaten gespeichert.
            Registry: {{ metrics.active_candidates }} aktiv, {{ metrics.rejected }} abgelehnt.
            <span class="text-slate-500" title="Wenn hier 0 Vorschlaege stehen, sind meist viele einzelne Ticker im 14-Tage-Cooldown oder der konfigurierte Sektorpool ist nach aktiven Bestandsausschluessen leer. Der Cooldown gilt pro Kandidat/Ticker, nicht pro Sektor.">Warum 0?</span>
        </section>

        <div class="mb-3 flex justify-end">
            <a class="rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-50" href="{{ path('app_watchlist_intake', {sort: sort.key, dir: sort.dir, page: 1, perPage: pagination.per_page, showRejected: showRejected ? 0 : 1}) }}">
                {{ showRejected ? 'Abgelehnte ausblenden' : 'Abgelehnte anzeigen' }}
            </a>
        </div>

        <section class="mb-5 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500">Top-Sektoren</h2>
            <div class="mt-3 grid gap-3 md:grid-cols-3">
                {% for sector in sectors %}
                    <div class="rounded-md border border-slate-200 p-3">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="font-semibold text-slate-950" title="Sector Rank: Rang innerhalb dieses Intake-Laufs nach Sektor-Score.">#{{ sector.sector_rank }} {{ sector.sector_label }}</p>
                                <p class="text-xs text-slate-500">{{ sector.proxy_ticker }}</p>
                            </div>
                            <span class="compact-badge bg-emerald-50 text-emerald-700 ring-emerald-200" title="Sector Score: 1M/3M Performance plus relative Staerke gegen SPY.">{{ sector.sector_score|number_format(1) }}</span>
                        </div>
                        <dl class="signal-stack mt-3">
                            <dt title="Performance des Sektor-Proxys ueber ca. einen Monat.">1M</dt><dt title="Performance des Sektor-Proxys ueber ca. drei Monate.">3M</dt><dt title="Relative 1M-Performance gegen SPY.">Rel 1M</dt><dt title="Relative 3M-Performance gegen SPY.">Rel 3M</dt>
                            <dd>{{ sector.return_1m_pct|number_format(1) }}%</dd>
                            <dd>{{ sector.return_3m_pct|number_format(1) }}%</dd>
                            <dd>{{ sector.relative_1m_pct|number_format(1) }}%</dd>
                            <dd>{{ sector.relative_3m_pct|number_format(1) }}%</dd>
                        </dl>
                    </div>
                {% endfor %}
            </div>
        </section>

        <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
            {% if pagination.pages > 1 %}
                <div class="flex items-center justify-between gap-3 border-b border-slate-100 px-4 py-3 text-sm">
                    <span class="text-slate-600">
                        Seite {{ pagination.page }} von {{ pagination.pages }} - {{ pagination.total }} Vorschlaege
                    </span>
                    <div class="flex gap-2">
                        <a class="rounded-md border border-slate-200 px-3 py-1 text-slate-700 hover:bg-slate-50 {{ pagination.page <= 1 ? 'pointer-events-none opacity-40' : '' }}" href="{{ path('app_watchlist_intake', {page: pagination.page - 1, perPage: pagination.per_page, sort: sort.key, dir: sort.dir, showRejected: showRejected ? 1 : 0}) }}">Zurueck</a>
                        <a class="rounded-md border border-slate-200 px-3 py-1 text-slate-700 hover:bg-slate-50 {{ pagination.page >= pagination.pages ? 'pointer-events-none opacity-40' : '' }}" href="{{ path('app_watchlist_intake', {page: pagination.page + 1, perPage: pagination.per_page, sort: sort.key, dir: sort.dir, showRejected: showRejected ? 1 : 0}) }}">Weiter</a>
                    </div>
                </div>
            {% endif %}
            <table class="data-table">
                <colgroup>
                    <col class="w-[8%]">
                    <col class="w-[12%]">
                    <col class="w-[13%]">
                    <col class="w-[19%]">
                    <col class="w-[11%]">
                    <col class="w-[8%]">
                    <col class="w-[14%]">
                    <col class="w-[10%]">
                </colgroup>
                <thead>
                    <tr>
                        <th>{{ table.sort_header('Ticker', 'ticker', sort, pagination, showRejected, 'Ticker aus der kumulativen Candidate Registry.') }}</th>
                        <th>{{ table.sort_header('Sektor', 'sector', sort, pagination, showRejected, 'Aktueller Sektor-Kontext aus der letzten Sichtung.') }}</th>
                        <th>{{ table.sort_header('Status', 'status', sort, pagination, showRejected, 'Registry Status: aktueller Vorschlagsstatus oder manuelle Nutzerentscheidung.') }}</th>
                        <th>{{ table.sort_header('SEPA', 'sepa', sort, pagination, showRejected, 'Sortiert nach SEPA Total als primaere Struktur- und Setup-Qualitaet.') }}</th>
                        <th>{{ table.sort_header('Merged Score', 'merged', sort, pagination, showRejected, 'Kombinierter Kronos-/Sentiment-Wert, sofern vorhanden.') }}</th>
                        <th>{{ table.sort_header('Seen Count', 'seen', sort, pagination, showRejected, 'Wie oft der Kandidat ueber Intake-Laeufe hinweg wieder aufgetaucht ist.') }}</th>
                        <th>{{ table.sort_header('Pruefung', 'pruefung', sort, pagination, showRejected, 'Letzte Sichtung und aktueller Grund der Proposal-Klasse.') }}</th>
                        <th title="Manuelle Aktion: zur Watchlist uebernehmen oder ablehnen.">Aktionen</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for candidate in candidates %}
                        {% set checks = candidate.hard_checks %}
                        {% set price = candidate.detail.price_strength ?? {} %}
                        {% set statusTone =
                            candidate.status == 'ACTIVE_CANDIDATE' ? 'bg-sky-50 text-sky-700 ring-sky-200' :
                            (candidate.status == 'ADDED_TO_WATCHLIST' ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' :
                            (candidate.status == 'REJECTED' ? 'bg-slate-100 text-slate-600 ring-slate-200' :
                            'bg-amber-50 text-amber-700 ring-amber-200')) %}
                        <tr>
                            <td>
                                <div class="font-semibold text-slate-950">{{ candidate.ticker }}</div>
                                {% if candidate.registry_priority is defined %}
                                    <div class="text-[11px] text-slate-500" title="Interne Default-Prioritaet aus Score, Persistenz, Frische und Status.">Prio {{ candidate.registry_priority|number_format(1) }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="font-medium text-slate-800">{{ candidate.sector_label }}</div>
                                <div class="text-[11px] text-slate-500" title="Erste und letzte Sichtung in der Registry.">{{ candidate.first_seen_at|date('d.m.') }} bis {{ candidate.last_seen_at|date('d.m.') }}</div>
                            </td>
                            <td>
                                <span class="compact-badge {{ statusTone }}" title="Proposal Status: Systemvorschlag oder manuelle Nutzerentscheidung.">{{ candidate.status }}</span>
                                <div class="mt-1 text-[11px] text-slate-500">{{ candidate.proposal_status }}</div>
                                <div class="mt-1 text-[11px] text-slate-500">Latest {{ candidate.latest_intake_score|number_format(1) }}</div>
                                <div class="text-[11px] text-slate-500">Best {{ candidate.best_intake_score|number_format(1) }}</div>
                                {% if checks.signal_source is defined %}
                                    <div class="mt-1 text-[11px] text-slate-500" title="Neuer Titel ohne DB-Snapshots: SEPA wird hier als leichter OHLCV-Proxy berechnet.">OHLCV-Proxy</div>
                                {% endif %}
                            </td>
                            <td>
                                <dl class="signal-stack max-w-[18rem]">
                                    <dt title="SEPA Structure: Trend, Stage, relative Staerke, Base, Volumen und Momentum.">Str</dt>
                                    <dt title="SEPA Execution: VCP, Mikrostruktur und Breakout Readiness.">Exe</dt>
                                    <dt title="SEPA Total: kombinierte Struktur- und Execution-Qualitaet.">Tot</dt>
                                    <dt title="Ampel: verdichtet SEPA-Qualitaet und Warnsignale.">Ampel</dt>
                                    <dd>{{ checks.sepa_structure is defined and checks.sepa_structure is not null ? checks.sepa_structure|number_format(1) : '-' }}</dd>
                                    <dd>{{ checks.sepa_execution is defined and checks.sepa_execution is not null ? checks.sepa_execution|number_format(1) : '-' }}</dd>
                                    <dd>{{ checks.sepa_total is defined and checks.sepa_total is not null ? checks.sepa_total|number_format(1) : '-' }}</dd>
                                    <dd>{{ checks.traffic_light ?? '-' }}</dd>
                                </dl>
                                {% if checks.epa_action is defined %}
                                    <div class="mt-1 text-[11px] text-slate-500" title="EPA wird hier nur angezeigt, aber nicht als Intake-Gate verwendet.">EPA Kontext: {{ checks.epa_action ?: '-' }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="font-semibold text-slate-950" title="Merged Score kombiniert Kronos und Sentiment, sofern bereits DB-Signale fuer diesen Kandidaten existieren.">
                                    {{ checks.merged_score is defined and checks.merged_score is not null ? checks.merged_score|number_format(3) : '-' }}
                                </div>
                                {% if price.price_score is defined %}
                                    <div class="mt-1 text-[11px] text-slate-500" title="Preisfilter bleibt Detailkontext aus dem Intake-Lauf, ist aber nicht der Merged Score.">Px {{ price.price_score|number_format(1) }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="font-semibold text-slate-950">{{ candidate.seen_count }}</div>
                                <div class="text-[11px] text-slate-500">Sichtungen</div>
                            </td>
                            <td class="text-xs text-slate-600">
                                <div title="Letzte Sichtung dieses Kandidaten in der Registry.">{{ candidate.last_seen_at|date('d.m. H:i') }}</div>
                                <div class="mt-1">{{ candidate.reason|replace({'_': ' '}) }}</div>
                            </td>
                            <td>
                                <div class="flex flex-col gap-1">
                                    <form method="post" action="{{ path('app_watchlist_intake_action', {id: candidate.id, action: 'add'}) }}">
                                        <button class="w-full rounded-md bg-slate-950 px-2 py-1 text-[11px] font-medium text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-300" title="Diesen Kandidaten manuell in die Watchlist aufnehmen." {{ candidate.status == 'ADDED_TO_WATCHLIST' ? 'disabled' : '' }}>Zur Watchlist</button>
                                    </form>
                                    <form method="post" action="{{ path('app_watchlist_intake_action', {id: candidate.id, action: 'dismiss'}) }}">
                                        <button class="w-full rounded-md border border-slate-200 px-2 py-1 text-[11px] font-medium text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:bg-slate-100" title="Diesen Vorschlag ablehnen und aus der aktiven Kandidatenliste ausblenden." {{ candidate.status == 'REJECTED' ? 'disabled' : '' }}>Ablehnen</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="8" class="py-6 text-center text-slate-500">Noch keine Kandidaten in der Registry.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
            {% if pagination.pages > 1 %}
                <div class="flex items-center justify-between gap-3 border-t border-slate-100 px-4 py-3 text-sm">
                    <span class="text-slate-600">
                        Zeige {{ candidates|length }} von {{ pagination.total }} Vorschlaegen
                    </span>
                    <div class="flex gap-2">
                        <a class="rounded-md border border-slate-200 px-3 py-1 text-slate-700 hover:bg-slate-50 {{ pagination.page <= 1 ? 'pointer-events-none opacity-40' : '' }}" href="{{ path('app_watchlist_intake', {page: pagination.page - 1, perPage: pagination.per_page, sort: sort.key, dir: sort.dir, showRejected: showRejected ? 1 : 0}) }}">Zurueck</a>
                        <a class="rounded-md border border-slate-200 px-3 py-1 text-slate-700 hover:bg-slate-50 {{ pagination.page >= pagination.pages ? 'pointer-events-none opacity-40' : '' }}" href="{{ path('app_watchlist_intake', {page: pagination.page + 1, perPage: pagination.per_page, sort: sort.key, dir: sort.dir, showRejected: showRejected ? 1 : 0}) }}">Weiter</a>
                    </div>
                </div>
            {% endif %}
        </section>
    {% endif %}
{% endblock %}
