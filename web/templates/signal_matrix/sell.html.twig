{% extends 'base.html.twig' %}
{% import 'dashboard/_ui.html.twig' as ui %}

{% block title %}Sell Signal Matrix{% endblock %}

{% block body %}
    {% set columns = {
        ticker: ['Ticker', 'Instrument-Detailseite'],
        name: ['Name / Meta', 'Name, WKN, Asset und Region'],
        scope: ['Scope', 'Portfolio oder Watchlist'],
        action: ['Action', 'EPA Handlungsklasse'],
        total: ['EPA', 'EPA Total, Failure, Trend Exit, Climax und Risk'],
        asOf: ['Aktualitaet', 'EPA Snapshot und letzter Run'],
        links: ['Links', 'Detail-Links']
    } %}

    <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <p class="text-sm font-medium uppercase text-slate-500">Sell Signal Matrix</p>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">Sell Signal Matrix</h1>
            <p class="mt-1 text-sm text-slate-600">Kompakte Verkaufsperspektive aus EPA / Exit & Risk Snapshots.</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm">
            <span class="font-medium text-slate-950">{{ items|length }}</span> aktive Instrumente
        </div>
    </div>

    <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
        <table class="data-table">
            <colgroup>
                <col class="w-[12%]">
                <col class="w-[24%]">
                <col class="w-[11%]">
                <col class="w-[13%]">
                <col class="w-[24%]">
                <col class="w-[12%]">
                <col class="w-[4%]">
            </colgroup>
            <thead>
                <tr>
                    {% for field, meta in columns %}
                        {% set sortField = field == 'links' ? currentSort : field %}
                        {% set nextDir = currentSort == sortField and currentDir == 'asc' ? 'desc' : 'asc' %}
                        {% set active = currentSort == sortField and field != 'links' %}
                        <th title="{{ meta[1] }}">
                            {% if field == 'links' %}
                                <span>{{ meta[0] }}</span>
                            {% else %}
                                <a class="inline-flex items-center gap-1 rounded px-1 py-0.5 {{ active ? 'text-slate-950' : 'text-slate-500 hover:text-slate-950' }}" href="{{ path('app_sell_signal_matrix', {sort: sortField, dir: nextDir}) }}">
                                    <span>{{ meta[0] }}</span>
                                    <span class="text-[10px]">{{ active ? (currentDir == 'asc' ? 'ASC' : 'DESC') : 'SORT' }}</span>
                                </a>
                            {% endif %}
                        </th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for item in items %}
                    <tr class="hover:bg-slate-50">
                        <td>
                            <a class="font-semibold text-slate-950 underline decoration-slate-300 underline-offset-4 hover:decoration-slate-900" href="{{ path('app_instrument_show', {id: item.instrument_id}) }}">{{ item.display_ticker ?: item.input_ticker }}</a>
                            <div class="mt-1 text-[11px] text-slate-500">{{ item.input_ticker }}</div>
                        </td>
                        <td>
                            <div class="truncate font-medium text-slate-800">{{ item.name ?: '-' }}</div>
                            <div class="mt-1 flex flex-wrap gap-1">
                                {{ ui.asset_badge(item.asset_class) }}
                                {% if item.region %}<span class="compact-badge bg-slate-100 text-slate-600 ring-slate-200">{{ item.region }}</span>{% endif %}
                                {% if item.wkn %}<span class="text-[11px] text-slate-500">WKN {{ item.wkn }}</span>{% endif %}
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-wrap gap-1">
                                <span class="compact-badge {{ item.is_portfolio ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' : 'bg-sky-50 text-sky-700 ring-sky-200' }}">{{ item.is_portfolio ? 'Portfolio' : 'Watchlist' }}</span>
                                <span class="compact-badge {{ item.active ? 'bg-slate-100 text-slate-700 ring-slate-200' : 'bg-rose-50 text-rose-700 ring-rose-200' }}">{{ item.active ? 'Aktiv' : 'Inaktiv' }}</span>
                            </div>
                        </td>
                        <td>
                            {{ item.action ? ui.epa_action_badge(item.action) : '-' }}
                            {% if item.epa_detail.action_reason is defined %}
                                <div class="mt-1 text-[11px] text-slate-500">{{ item.epa_detail.action_reason|replace({'_': ' '}) }}</div>
                            {% endif %}
                        </td>
                        <td>
                            {% if item.epa_total_score is not null %}
                                <dl class="signal-stack max-w-[18rem]">
                                    <dt>Tot</dt><dt>Fail</dt><dt>Trend</dt><dt>Clx</dt><dt>Risk</dt>
                                    <dd class="text-slate-950">{{ item.epa_total_score|number_format(1) }}</dd>
                                    <dd>{{ item.failure_score|number_format(1) }}</dd>
                                    <dd>{{ item.trend_exit_score|number_format(1) }}</dd>
                                    <dd>{{ item.climax_score|number_format(1) }}</dd>
                                    <dd>{{ item.risk_score|number_format(1) }}</dd>
                                </dl>
                                {% set hardCount = item.hard_triggers|length %}
                                {% set softCount = item.soft_warnings|length %}
                                <div class="mt-1 text-[11px] text-slate-500">Hard {{ hardCount }} / Soft {{ softCount }}</div>
                            {% else %}
                                <span class="text-slate-400">-</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="space-y-0.5 text-[11px] text-slate-600">
                                <div>EPA: {{ item.epa_as_of_date ? item.epa_as_of_date|date('d.m.y') : '-' }}</div>
                                <div>Run: {{ item.last_run_at ? item.last_run_at|date('d.m. H:i') : '-' }}</div>
                            </div>
                        </td>
                        <td>
                            <div class="space-y-0.5 text-[11px]">
                                <a class="block text-slate-500 underline decoration-slate-300 underline-offset-4 hover:text-slate-950" href="{{ path('app_instrument_show', {id: item.instrument_id}) }}">Inst</a>
                                {% if item.run_id %}
                                    <a class="block text-slate-500 underline decoration-slate-300 underline-offset-4 hover:text-slate-950" href="{{ path('app_run_show', {id: item.run_id}) }}">Run</a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td class="px-4 py-6 text-center text-slate-500" colspan="{{ columns|length }}">Keine EPA-Signale vorhanden.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
