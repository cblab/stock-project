<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Stock Pipeline{% endblock %}</title>
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-slate-50 text-slate-900">
        <header class="border-b border-slate-200 bg-white">
            <div class="mx-auto flex max-w-screen-2xl items-center justify-between px-4 py-4 2xl:px-6">
                <a class="text-base font-semibold text-slate-950" href="{{ path('app_runs_index') }}">Stock Pipeline</a>
                <nav class="flex items-center gap-4 text-sm text-slate-500">
                    <a class="hover:text-slate-950" href="{{ path('app_runs_index') }}">Runs</a>
                    <a class="hover:text-slate-950" href="{{ path('app_buy_signal_matrix') }}">Buy Matrix</a>
                    <a class="hover:text-slate-950" href="{{ path('app_sell_signal_matrix') }}">Sell Matrix</a>
                    <a class="hover:text-slate-950" href="{{ path('app_portfolio_index') }}">Portfolio</a>
                    <a class="hover:text-slate-950" href="{{ path('app_watchlist_index') }}">Watchlist</a>
                    <a class="hover:text-slate-950" href="{{ path('app_watchlist_intake') }}">Intake</a>
                    <a class="hover:text-slate-950" href="{{ path('app_instruments_inactive') }}">Inaktive</a>
                </nav>
            </div>
        </header>
        <main class="mx-auto max-w-screen-2xl px-4 py-5 2xl:px-6">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
