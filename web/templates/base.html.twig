<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Stock Pipeline{% endblock %}</title>
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-slate-50 text-slate-900">
        <header class="border-b border-slate-200 bg-white">
            <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
                <a class="text-base font-semibold text-slate-950" href="{{ path('app_runs_index') }}">Stock Pipeline</a>
                <nav class="flex items-center gap-4 text-sm text-slate-500">
                    <a class="hover:text-slate-950" href="{{ path('app_runs_index') }}">Runs</a>
                    <a class="hover:text-slate-950" href="{{ path('app_portfolio_index') }}">Portfolio</a>
                    <a class="hover:text-slate-950" href="{{ path('app_watchlist_index') }}">Watchlist</a>
                </nav>
            </div>
        </header>
        <main class="mx-auto max-w-7xl px-6 py-6">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm {{ label == 'success' ? 'text-emerald-700' : 'text-slate-700' }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
