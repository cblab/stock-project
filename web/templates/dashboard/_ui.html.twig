{% macro decision_badge(decision) %}
    {% set classes = decision == 'ENTRY' ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' : (decision == 'WATCH' ? 'bg-blue-50 text-blue-700 ring-blue-200' : (decision == 'NO TRADE' ? 'bg-rose-50 text-rose-700 ring-rose-200' : 'bg-slate-100 text-slate-700 ring-slate-200')) %}
    {% set tooltip = decision == 'ENTRY' ? 'ENTRY: merged_score >= 0.35, stark positives kombiniertes Signal.' : (decision == 'WATCH' ? 'WATCH: merged_score >= 0.15 und < 0.35, positiv aber noch kein Entry.' : (decision == 'NO TRADE' ? 'NO TRADE: merged_score <= -0.15, negatives kombiniertes Signal.' : 'HOLD: merged_score zwischen -0.15 und 0.15, gemischtes oder schwaches Signal.')) %}
    <span class="compact-badge {{ classes }}" title="{{ tooltip }}">{{ decision }}</span>
{% endmacro %}

{% macro asset_badge(assetClass) %}
    {% set isEtf = assetClass == 'ETF' %}
    <span class="compact-badge {{ isEtf ? 'bg-violet-50 text-violet-700 ring-violet-200' : 'bg-slate-100 text-slate-700 ring-slate-200' }}" title="{{ isEtf ? 'ETF: Sentiment laeuft primaer ueber Kontext, Holdings und Makroprofil.' : 'Equity: Sentiment laeuft primaer ueber direkte Ticker-News.' }}">{{ assetClass }}</span>
{% endmacro %}

{% macro mode_badge(mode) %}
    {% set tooltip = mode == 'etf_context' ? 'etf_context: ETF-Sentiment nutzt Kontextpfad statt nur direkte ETF-News.' : (mode == 'equity_direct' ? 'equity_direct: Sentiment basiert auf direkten Ticker-News.' : 'Sentiment-Modus aus dem Pipeline-Explain-JSON.') %}
    <span class="compact-badge bg-white text-slate-700 ring-slate-200" title="{{ tooltip }}">{{ mode ?: '-' }}</span>
{% endmacro %}

{% macro status_badge(status) %}
    {% set ok = status == 'ok' %}
    {% set warn = status in ['no_articles', 'profile_only'] %}
    {% set classes = ok ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' : (warn ? 'bg-amber-50 text-amber-700 ring-amber-200' : 'bg-slate-100 text-slate-700 ring-slate-200') %}
    <span class="compact-badge {{ classes }}" title="Status aus Pipeline-Run: {{ status ?: '-' }}">{{ status ?: '-' }}</span>
{% endmacro %}

{% macro relevance_badge(relevance) %}
    {% set classes = relevance == 'direct' ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' : (relevance == 'related' ? 'bg-blue-50 text-blue-700 ring-blue-200' : 'bg-slate-100 text-slate-700 ring-slate-200') %}
    {% set tooltip = relevance == 'direct' ? 'Direct: Titel oder Snippet enthaelt das Ticker-/Provider-Symbol.' : (relevance == 'related' ? 'Related: Kontext, Holdings oder ETF-Lookthrough passt zum Ticker.' : 'Weak: nur lose thematische Naehe; heuristische Relevanz.') %}
    <span class="rounded-full px-2 py-1 text-xs font-medium ring-1 {{ classes }}" title="{{ tooltip }}">{{ relevance }}</span>
{% endmacro %}

{% macro clamp_badge(clamp) %}
    {% if clamp %}
        {% set classes = clamp.tone == 'upper' ? 'bg-amber-50 text-amber-800 ring-amber-200' : 'bg-rose-50 text-rose-700 ring-rose-200' %}
        <span class="rounded-full px-2 py-1 text-xs font-medium ring-1 {{ classes }}" title="Normalisierung hat die Grenze erreicht; starkes Signal, aber kein perfekter Score.">{{ clamp.label }}</span>
    {% endif %}
{% endmacro %}

{% macro score_bar(value, marker, label) %}
    {% set display = value is not null ? value|number_format(3) : '-' %}
    <div class="space-y-1" title="{{ label }} im Bereich [-1, 1]. Positive Werte sprechen fuer Long-/Watch-Signale, negative Werte dagegen.">
        <div class="flex items-center justify-between text-xs text-slate-500">
            <span>-1</span>
            <span class="font-medium text-slate-800">{{ display }}</span>
            <span>+1</span>
        </div>
        <div class="relative h-2 rounded-full bg-gradient-to-r from-rose-200 via-slate-200 to-emerald-200">
            <span class="absolute left-1/2 top-0 h-2 w-px bg-slate-500"></span>
            <span class="absolute top-[-3px] h-4 w-1.5 rounded-full bg-slate-950" style="left: calc({{ marker }}% - 3px)"></span>
        </div>
    </div>
{% endmacro %}

{% macro threshold_bar(value, marker) %}
    <div class="space-y-2" title="Thresholds: NO TRADE <= -0.15, HOLD bis 0.15, WATCH ab 0.15, ENTRY ab 0.35.">
        <div class="relative h-3 rounded-full bg-gradient-to-r from-rose-200 via-slate-200 to-emerald-200">
            <span class="absolute top-[-5px] h-5 w-px bg-rose-500" style="left: 42.5%" title="-0.15 NO TRADE/HOLD"></span>
            <span class="absolute top-[-5px] h-5 w-px bg-blue-500" style="left: 57.5%" title="0.15 WATCH"></span>
            <span class="absolute top-[-5px] h-5 w-px bg-emerald-600" style="left: 67.5%" title="0.35 ENTRY"></span>
            <span class="absolute top-[-4px] h-5 w-1.5 rounded-full bg-slate-950" style="left: calc({{ marker }}% - 3px)" title="Aktueller Merged Score {{ value is not null ? value|number_format(3) : '-' }}"></span>
        </div>
        <div class="grid grid-cols-4 text-xs text-slate-500">
            <span>NO TRADE</span>
            <span>HOLD</span>
            <span>WATCH</span>
            <span class="text-right">ENTRY</span>
        </div>
    </div>
{% endmacro %}
