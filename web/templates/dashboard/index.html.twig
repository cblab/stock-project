{% extends 'base.html.twig' %}
{% import 'dashboard/_ui.html.twig' as ui %}

{% block title %}Pipeline Runs{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <p class="text-sm font-medium uppercase text-slate-500">Persistierte Analyse-Runs</p>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">Stock Pipeline Dashboard</h1>
        </div>
        <div class="flex flex-wrap gap-2">
            <form method="post" action="{{ path('app_runs_start', {source: 'portfolio'}) }}">
                <button class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm ring-1 ring-emerald-700/20 hover:bg-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2" type="submit" title="Startet die Pipeline fuer aktive Portfolio-Instrumente.">
                    Portfolio-Run starten
                </button>
            </form>
            <form method="post" action="{{ path('app_runs_start', {source: 'watchlist'}) }}">
                <button class="rounded-md bg-sky-600 px-4 py-2 text-sm font-semibold text-white shadow-sm ring-1 ring-sky-700/20 hover:bg-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2" type="submit" title="Startet die Pipeline fuer aktive Watchlist-Instrumente.">
                    Watchlist-Run starten
                </button>
            </form>
        </div>
    </div>

    {% if runs is empty %}
        <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-base font-semibold text-slate-950">Noch keine Runs importiert</h2>
            <p class="mt-2 text-sm text-slate-600">Importiere einen bestehenden Pipeline-Run mit <code class="rounded bg-slate-100 px-1 py-0.5">php bin/console app:import-run --path="E:/stock-project/runs/YYYY-MM-DD_HH-MM"</code>.</p>
        </section>
    {% else %}
        {% set newest = runs|first %}
        <div class="grid gap-4 md:grid-cols-4">
            <div class="metric-card">
                <p class="text-xs font-semibold uppercase text-slate-500">Neuester Run</p>
                <p class="mt-2 text-xl font-semibold text-slate-950">{{ newest.runKey }}</p>
            </div>
            <div class="metric-card">
                <p class="text-xs font-semibold uppercase text-slate-500">Ticker</p>
                <p class="mt-2 text-xl font-semibold text-slate-950">{{ newest.displayItems|length }}</p>
            </div>
            <div class="metric-card">
                <p class="text-xs font-semibold uppercase text-slate-500">ENTRY / WATCH</p>
                <p class="mt-2 text-xl font-semibold text-slate-950">{{ newest.decisionEntryCount }} / {{ newest.decisionWatchCount }}</p>
            </div>
            <div class="metric-card">
                <p class="text-xs font-semibold uppercase text-slate-500">Score-Spanne</p>
                <p class="mt-2 text-xl font-semibold text-slate-950">{{ newest.scoreMin is not null ? newest.scoreMin|number_format(3) : '-' }} bis {{ newest.scoreMax is not null ? newest.scoreMax|number_format(3) : '-' }}</p>
            </div>
        </div>

        <section class="mt-6 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Run</th>
                        <th>Status</th>
                        <th>Scope</th>
                        <th>Start</th>
                        <th>Exit</th>
                        <th>Ticker</th>
                        <th>ENTRY</th>
                        <th>WATCH</th>
                        <th>HOLD</th>
                        <th>NO TRADE</th>
                        <th>Score Mean</th>
                        <th>Fehler / Logs</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for run in runs %}
                        {% set isWatchlist = run.runScope == 'watchlist' %}
                        {% set isRefresh = run.runScope == 'snapshot_refresh' %}
                        <tr class="{{ isRefresh ? 'bg-violet-50/25' : (isWatchlist ? 'bg-sky-50/35' : 'bg-emerald-50/25') }} hover:bg-slate-50">
                            <td class="font-medium text-slate-950">{{ run.runKey }}</td>
                            <td>{{ ui.run_status_badge(run.status) }}</td>
                            <td>
                                <span class="rounded-full px-2.5 py-1 text-xs font-medium ring-1 {{ isRefresh ? 'bg-violet-50 text-violet-700 ring-violet-200' : (isWatchlist ? 'bg-sky-50 text-sky-700 ring-sky-200' : 'bg-emerald-50 text-emerald-700 ring-emerald-200') }}">
                                    {{ isRefresh ? 'Snapshot' : (isWatchlist ? 'Watchlist' : 'Portfolio') }}
                                </span>
                            </td>
                            <td>{{ run.startedAt ? run.startedAt|date('d.m.Y H:i') : '-' }}</td>
                            <td>{{ run.exitCode is not null ? run.exitCode : '-' }}</td>
                            <td>{{ run.displayItems|length }}</td>
                            <td>{{ run.decisionEntryCount }}</td>
                            <td>{{ run.decisionWatchCount }}</td>
                            <td>{{ run.decisionHoldCount }}</td>
                            <td>{{ run.decisionNoTradeCount }}</td>
                            <td>{{ run.scoreMean is not null ? run.scoreMean|number_format(3) : '-' }}</td>
                            <td class="max-w-[18rem] text-xs text-slate-600">
                                <div class="truncate" title="{{ run.errorSummary ?: run.notes ?: '' }}">{{ run.errorSummary ?: '-' }}</div>
                                {% if run.stdoutLogPath or run.stderrLogPath %}
                                    <div class="mt-1 truncate text-[11px] text-slate-400" title="{{ (run.stdoutLogPath ?: '-') ~ ' / ' ~ (run.stderrLogPath ?: '-') }}">Logs gesetzt</div>
                                {% endif %}
                            </td>
                            <td class="text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a class="font-medium text-slate-950 underline decoration-slate-300 underline-offset-4 hover:decoration-slate-900" href="{{ path('app_run_show', {id: run.id}) }}">Details</a>
                                    <form method="post" action="{{ path('app_run_delete', {id: run.id}) }}" onsubmit="return confirm('Run {{ run.runKey }} wirklich loeschen?');">
                                        <button class="text-sm font-medium text-rose-700 underline decoration-rose-200 underline-offset-4 hover:decoration-rose-700" type="submit">Löschen</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    {% endif %}
{% endblock %}
