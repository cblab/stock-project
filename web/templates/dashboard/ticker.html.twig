{% extends 'base.html.twig' %}
{% import 'dashboard/_ui.html.twig' as ui %}

{% block title %}{{ ticker.displayTicker }}{% endblock %}

{% block body %}
    {% set isEtf = ticker.assetClass == 'ETF' %}
    {% set articlesAnalyzed = explain.sentiment_articles_analyzed ?? explain.articles_analyzed ?? view.articles|length %}
    {% set mergeWeights = view.mergeWeights %}

    <div class="mb-6">
        <a class="text-sm text-slate-500 hover:text-slate-950" href="{{ path('app_run_show', {id: run.id}) }}">Zurueck zu Run {{ run.runId }}</a>
        <div class="mt-3 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div>
                    <div class="flex flex-wrap items-center gap-3">
                        <h1 class="text-3xl font-semibold text-slate-950">{{ ticker.displayTicker }}</h1>
                        {{ ui.decision_badge(ticker.decision) }}
                        {{ ui.asset_badge(ticker.assetClass) }}
                        {{ ui.mode_badge(ticker.sentimentMode) }}
                    </div>
                    <p class="mt-2 text-sm text-slate-600">
                        {{ ticker.instrument.name ?: 'Kein Name gepflegt' }}
                        {% if ticker.instrument.wkn %}| WKN {{ ticker.instrument.wkn }}{% endif %}
                        | Provider {{ ticker.providerTicker }} | Region {{ ticker.region ?: '-' }} | Backend {{ ticker.sentimentBackend ?: '-' }}
                    </p>
                </div>
                <dl class="grid gap-3 text-sm sm:grid-cols-2 lg:min-w-[28rem]">
                    <div class="rounded-md bg-slate-50 p-3" title="Kombinierter Score aus Kronos und Sentiment">
                        <dt class="text-xs uppercase text-slate-500">Merged Score</dt>
                        <dd class="mt-1 text-xl font-semibold text-slate-950">{{ ticker.mergedScore is not null ? ticker.mergedScore|number_format(4) : '-' }}</dd>
                    </div>
                    <div class="rounded-md bg-slate-50 p-3" title="Kronos-Forecast-Horizont aus Explain-JSON">
                        <dt class="text-xs uppercase text-slate-500">Kronos Horizon</dt>
                        <dd class="mt-1 font-semibold text-slate-950">{{ explain.kronos_horizon_label ?? run.horizonLabel ?? '-' }}</dd>
                    </div>
                    <div class="rounded-md bg-slate-50 p-3" title="Zeitpunkt der Kronos-Signal-Erzeugung">
                        <dt class="text-xs uppercase text-slate-500">Generated</dt>
                        <dd class="mt-1 font-medium text-slate-950">{{ view.generatedAt ?? '-' }}</dd>
                    </div>
                    <div class="rounded-md bg-slate-50 p-3" title="Zeitpunkt, bis zu dem der Kronos-Score als aktuell gilt">
                        <dt class="text-xs uppercase text-slate-500">Valid Until</dt>
                        <dd class="mt-1 font-medium text-slate-950">{{ view.validUntil ?? '-' }}</dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>

    <section class="mb-6 rounded-lg border border-slate-200 bg-slate-50/70 p-4 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Letzter Lauf (Instrument)</h2>
            {% if lastRunItem %}
                <a class="text-sm font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 hover:text-slate-950 hover:decoration-slate-900" href="{{ path('app_run_show', {id: lastRunItem.pipelineRun.id}) }}">Run oeffnen</a>
            {% endif %}
        </div>

        {% if lastRunItem %}
            {% set runScope = lastRunItem.instrument.portfolio ? 'Portfolio' : 'Watchlist' %}
            {% if isCurrentRunLatest %}
                <p class="mt-2 text-xs text-emerald-700">Dies ist zugleich der letzte Lauf dieses Instruments.</p>
            {% endif %}
            <div class="mt-3 flex flex-wrap gap-2">
                {{ ui.decision_badge(lastRunItem.decision) }}
                <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200">{{ runScope }}</span>
                <span class="rounded-full bg-white px-2 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200">{{ lastRunItem.sentimentLabel ?: 'sentiment n/a' }}</span>
                {{ ui.status_badge(lastRunItem.marketDataStatus) }}
                {{ ui.status_badge(lastRunItem.newsStatus) }}
            </div>

            <dl class="mt-4 grid gap-3 text-sm md:grid-cols-2 lg:grid-cols-4">
                <div>
                    <dt class="text-slate-500">Run-Zeit</dt>
                    <dd class="font-medium text-slate-900">{{ (lastRunItem.pipelineRun.startedAt ?: lastRunItem.pipelineRun.createdAt)|date('d.m.Y H:i') }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Run-ID</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.pipelineRun.runId }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Sentiment Mode</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.sentimentMode ?: '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Decision</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.decision ?: '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">K Norm</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.kronosNormalizedScore is not null ? lastRunItem.kronosNormalizedScore|number_format(2) : '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">S Norm</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.sentimentNormalizedScore is not null ? lastRunItem.sentimentNormalizedScore|number_format(2) : '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Merged</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.mergedScore is not null ? lastRunItem.mergedScore|number_format(2) : '-' }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Data / News</dt>
                    <dd class="font-medium text-slate-900">{{ lastRunItem.marketDataStatus ?: '-' }} / {{ lastRunItem.newsStatus ?: '-' }}</dd>
                </div>
            </dl>

            <div class="mt-4 flex flex-wrap gap-4 text-sm">
                <a class="font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 hover:text-slate-950 hover:decoration-slate-900" href="{{ path('app_run_show', {id: lastRunItem.pipelineRun.id}) }}">Zugehoerigen Run</a>
                <a class="font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 hover:text-slate-950 hover:decoration-slate-900" href="{{ path('app_ticker_show', {id: lastRunItem.id}) }}">Ticker im letzten Run</a>
                <a class="font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 hover:text-slate-950 hover:decoration-slate-900" href="{{ path('app_instrument_show', {id: lastRunItem.instrument.id}) }}">Instrument</a>
            </div>
        {% else %}
            <p class="mt-3 text-sm text-slate-600">Noch kein Lauf fuer dieses Instrument vorhanden.</p>
        {% endif %}
    </section>

    <div class="grid gap-4 lg:grid-cols-3">
        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500" title="Kronos liefert Preis-/OHLCV-basiertes Richtungssignal.">Kronos</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4"><dt class="text-slate-500">K Raw</dt><dd class="text-right font-medium">{{ ticker.kronosRawScore is not null ? ticker.kronosRawScore|number_format(5) : '-' }}<br><span class="text-xs font-normal text-slate-500">Forecast Return {{ explain.kronos_horizon_label ?? run.horizonLabel ?? '-' }}: {{ view.kronosRawPercent is not null ? (view.kronosRawPercent > 0 ? '+' : '') ~ view.kronosRawPercent|number_format(2) ~ '%' : '-' }}</span></dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">K Norm</dt><dd class="text-right font-medium">{{ ticker.kronosNormalizedScore is not null ? ticker.kronosNormalizedScore|number_format(4) : '-' }}<br>{{ ui.clamp_badge(view.kronosClamp) }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Direction</dt><dd class="font-medium">{{ ticker.kronosDirection ?: '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Horizon</dt><dd class="font-medium">{{ explain.kronos_horizon_label ?? run.horizonLabel ?? '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Frequency</dt><dd class="font-medium">{{ explain.kronos_data_frequency ?? run.dataFrequency ?? '-' }}</dd></div>
            </dl>
            <div class="mt-4">{{ ui.score_bar(ticker.kronosNormalizedScore, view.scorePositions.kronos, 'Kronos normalized score') }}</div>
        </section>

        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500" title="Sentiment fasst News-Artikel mit FinBERT bzw. ETF-Kontext zusammen.">Sentiment</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4"><dt class="text-slate-500">S Raw</dt><dd class="font-medium">{{ ticker.sentimentRawScore is not null ? ticker.sentimentRawScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">S Norm</dt><dd class="font-medium">{{ ticker.sentimentNormalizedScore is not null ? ticker.sentimentNormalizedScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Label</dt><dd class="font-medium">{{ ticker.sentimentLabel ?: '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Confidence</dt><dd class="font-medium">{{ ticker.sentimentConfidence is not null ? ticker.sentimentConfidence|number_format(3) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Articles</dt><dd class="font-medium">{{ articlesAnalyzed }}</dd></div>
            </dl>
            <div class="mt-4 grid grid-cols-3 gap-2 text-xs">
                <div class="rounded-md bg-emerald-50 p-2 text-emerald-800" title="Anzahl positiver Artikel im Sentiment-Explain"><span class="block text-slate-500">Positive</span><strong>{{ view.sentimentDistribution.positive }}</strong></div>
                <div class="rounded-md bg-slate-100 p-2 text-slate-800" title="Anzahl neutraler Artikel im Sentiment-Explain"><span class="block text-slate-500">Neutral</span><strong>{{ view.sentimentDistribution.neutral }}</strong></div>
                <div class="rounded-md bg-rose-50 p-2 text-rose-800" title="Anzahl negativer Artikel im Sentiment-Explain"><span class="block text-slate-500">Negative</span><strong>{{ view.sentimentDistribution.negative }}</strong></div>
            </div>
            <div class="mt-4">{{ ui.score_bar(ticker.sentimentNormalizedScore, view.scorePositions.sentiment, 'Sentiment normalized score') }}</div>
        </section>

        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500" title="Merged kombiniert Kronos und Sentiment nach festen Gewichten.">Merged</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Merged</dt><dd class="font-semibold">{{ ticker.mergedScore is not null ? ticker.mergedScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Decision</dt><dd>{{ ui.decision_badge(ticker.decision) }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">K Weight</dt><dd class="font-medium">{{ mergeWeights.kronos ?? 0.6 }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">S Weight</dt><dd class="font-medium">{{ mergeWeights.sentiment ?? 0.4 }}</dd></div>
            </dl>
            <div class="mt-4">{{ ui.threshold_bar(ticker.mergedScore, view.scorePositions.merged) }}</div>
        </section>
    </div>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Decision Breakdown</h2>
        <p class="mt-2 text-sm text-slate-700">{{ view.signalSummary }}</p>
        <p class="mt-1 text-sm text-slate-700">{{ view.decisionReason }}</p>
        <div class="mt-4 grid gap-3 text-sm md:grid-cols-4">
            <div class="rounded-md bg-slate-50 p-3" title="Rechnerische Merge-Gleichung"><span class="text-slate-500">Equation</span><p class="mt-1 font-semibold">{{ view.decisionMath }}</p></div>
            <div class="rounded-md bg-slate-50 p-3" title="Getroffene Decision-Schwelle"><span class="text-slate-500">Threshold</span><p class="mt-1 font-semibold">{{ view.decisionThreshold }}</p></div>
            <div class="rounded-md bg-slate-50 p-3" title="Datenqualitaet fuer diesen Ticker"><span class="text-slate-500">Data Health</span><p class="mt-1 font-semibold">{{ ticker.marketDataStatus ?: '-' }} / {{ ticker.newsStatus ?: '-' }}</p></div>
            <div class="rounded-md bg-slate-50 p-3" title="Kronos-Rohsignal als erwartete Rendite ueber den Forecast-Horizont"><span class="text-slate-500">Forecast Return</span><p class="mt-1 font-semibold">{{ view.kronosRawPercent is not null ? (view.kronosRawPercent > 0 ? '+' : '') ~ view.kronosRawPercent|number_format(2) ~ '%' : '-' }}</p></div>
        </div>
    </section>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Kronos Details</h2>
        <div class="mt-3 grid gap-4 text-sm md:grid-cols-2 lg:grid-cols-4">
            <div><p class="text-slate-500">Direction</p><p class="font-medium">{{ ticker.kronosDirection ?: '-' }}</p></div>
            <div><p class="text-slate-500">Raw Score</p><p class="font-medium">{{ ticker.kronosRawScore is not null ? ticker.kronosRawScore|number_format(6) : '-' }}</p><p class="text-xs text-slate-500">Forecast Return: {{ view.kronosRawPercent is not null ? (view.kronosRawPercent > 0 ? '+' : '') ~ view.kronosRawPercent|number_format(2) ~ '%' : '-' }}</p></div>
            <div><p class="text-slate-500">Normalized</p><p class="font-medium">{{ ticker.kronosNormalizedScore is not null ? ticker.kronosNormalizedScore|number_format(4) : '-' }}</p><p class="mt-1">{{ ui.clamp_badge(view.kronosClamp) }}</p></div>
            <div><p class="text-slate-500">Data Frequency</p><p class="font-medium">{{ explain.kronos_data_frequency ?? run.dataFrequency ?? '-' }}</p></div>
            <div><p class="text-slate-500">Horizon Steps</p><p class="font-medium">{{ explain.kronos_horizon_steps ?? run.horizonSteps ?? '-' }}</p></div>
            <div><p class="text-slate-500">Horizon Label</p><p class="font-medium">{{ explain.kronos_horizon_label ?? run.horizonLabel ?? '-' }}</p></div>
            <div><p class="text-slate-500">Generated At</p><p class="font-medium">{{ view.generatedAt ?? '-' }}</p></div>
            <div><p class="text-slate-500">Valid Until</p><p class="font-medium">{{ view.validUntil ?? '-' }}</p></div>
        </div>
        {% if explain.raw_forecast is defined %}
            <pre class="mt-4 max-h-64 overflow-auto rounded-md bg-slate-950 p-4 text-xs text-slate-100">{{ explain.raw_forecast|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
        {% else %}
            <p class="mt-4 text-sm text-slate-600">Keine separaten Forecast-Reihen im Explain-JSON gefunden; angezeigt werden die normalisierten Kronos-Signale und der Forecast-Horizont.</p>
        {% endif %}
    </section>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
            <div>
                <h2 class="text-sm font-semibold uppercase text-slate-500">Sentiment & News</h2>
                <p class="mt-1 text-sm text-slate-600">{{ explain.final_sentiment_reason ?? 'Sentiment-Quelle aus Explain-JSON.' }}</p>
            </div>
            <div class="text-sm text-slate-600">{{ articlesAnalyzed }} Artikel analysiert | {{ ticker.sentimentBackend ?: '-' }}</div>
        </div>

        <div class="mt-4 grid gap-3 text-sm md:grid-cols-5">
            <div><p class="text-slate-500">Label</p><p class="font-medium">{{ ticker.sentimentLabel ?: '-' }}</p></div>
            <div><p class="text-slate-500">S Raw</p><p class="font-medium">{{ ticker.sentimentRawScore is not null ? ticker.sentimentRawScore|number_format(4) : '-' }}</p></div>
            <div><p class="text-slate-500">S Norm</p><p class="font-medium">{{ ticker.sentimentNormalizedScore is not null ? ticker.sentimentNormalizedScore|number_format(4) : '-' }}</p></div>
            <div><p class="text-slate-500">Confidence</p><p class="font-medium">{{ ticker.sentimentConfidence is not null ? ticker.sentimentConfidence|number_format(3) : '-' }}</p></div>
            <div><p class="text-slate-500">Mode</p><p>{{ ui.mode_badge(ticker.sentimentMode) }}</p></div>
        </div>
        <div class="mt-4 flex flex-wrap gap-2 text-xs">
            <span class="rounded-full bg-emerald-50 px-2.5 py-1 font-medium text-emerald-800 ring-1 ring-emerald-200">Positive {{ view.sentimentDistribution.positive }}</span>
            <span class="rounded-full bg-slate-100 px-2.5 py-1 font-medium text-slate-800 ring-1 ring-slate-200">Neutral {{ view.sentimentDistribution.neutral }}</span>
            <span class="rounded-full bg-rose-50 px-2.5 py-1 font-medium text-rose-800 ring-1 ring-rose-200">Negative {{ view.sentimentDistribution.negative }}</span>
            <span class="rounded-full bg-white px-2.5 py-1 font-medium text-slate-700 ring-1 ring-slate-200">Total {{ view.sentimentDistribution.total }}</span>
        </div>

        {% if view.articleGroups is empty %}
            <div class="mt-5 rounded-md border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
                Keine konkreten Artikel im persistierten Explain-JSON gefunden. Nach einem Re-Import aktueller Runs werden `signals/sentiment/*` und `input/*_news.json` in `explainJson` uebernommen.
            </div>
        {% else %}
            {% for groupName, articles in view.articleGroups %}
                <div class="mt-6">
                    <h3 class="text-sm font-semibold text-slate-950">{{ groupName|replace({'_': ' '})|title }}</h3>
                    <div class="mt-2 overflow-x-auto rounded-md border border-slate-200">
                        <table class="min-w-full divide-y divide-slate-200 text-sm">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="px-3 py-2 text-left font-semibold text-slate-500">Time</th>
                                    <th class="px-3 py-2 text-left font-semibold text-slate-500">Source</th>
                                    <th class="px-3 py-2 text-left font-semibold text-slate-500">Headline</th>
                                    <th class="px-3 py-2 text-left font-semibold text-slate-500" title="Heuristische Relevanz: direct, related oder weak.">Relevance</th>
                                    <th class="px-3 py-2 text-left font-semibold text-slate-500">Snippet</th>
                                    <th class="px-3 py-2 text-left font-semibold text-slate-500">Article Sentiment</th>
                                    <th class="px-3 py-2 text-left font-semibold text-slate-500">Confidence</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 bg-white">
                                {% for article in articles %}
                                    <tr class="align-top">
                                        <td class="whitespace-nowrap px-3 py-2 text-slate-600">{{ article.formatted_published_at ?? article.published_at ?? '-' }}</td>
                                        <td class="whitespace-nowrap px-3 py-2 text-slate-600">{{ article.source ?? '-' }}</td>
                                        <td class="min-w-[18rem] px-3 py-2 font-medium text-slate-950">
                                            {% if article.url is defined and article.url %}
                                                <a class="underline decoration-slate-300 underline-offset-4 hover:decoration-slate-900" href="{{ article.url }}" target="_blank" rel="noreferrer">{{ article.title ?? '-' }}</a>
                                            {% else %}
                                                {{ article.title ?? '-' }}
                                            {% endif %}
                                        </td>
                                        <td class="whitespace-nowrap px-3 py-2">{{ ui.relevance_badge(article.relevance ?? 'weak') }}</td>
                                        <td class="min-w-[20rem] px-3 py-2 text-slate-600">{{ article.summary ?? article.snippet ?? '-' }}</td>
                                        <td class="whitespace-nowrap px-3 py-2">{{ article.label ?? article.raw_label ?? '-' }}</td>
                                        <td class="whitespace-nowrap px-3 py-2">{{ article.confidence is defined ? article.confidence|number_format(3) : '-' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </section>

    {% if isEtf %}
        <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500">ETF Context</h2>
            <p class="mt-1 text-sm text-slate-600">Direkte ETF-News sind sekundaer; der Kontextpfad nutzt Benchmark, Regionen, Sektoren, Holdings und Makroprofil.</p>
            <div class="mt-3 grid gap-4 text-sm md:grid-cols-2">
                <div><p class="text-slate-500">Benchmark</p><p class="font-medium">{{ explain.benchmark ?? '-' }}</p></div>
                <div><p class="text-slate-500">Direct News Status</p><p class="font-medium">{{ explain.direct_news_status ?? '-' }}</p></div>
                <div><p class="text-slate-500">Region Exposure</p><p class="font-medium">{{ explain.region_exposure is defined ? explain.region_exposure|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Sector Profile</p><p class="font-medium">{{ explain.sector_profile is defined ? explain.sector_profile|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Top Holdings</p><p class="font-medium">{{ explain.top_holdings_profile is defined ? explain.top_holdings_profile|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Macro Profile</p><p class="font-medium">{{ explain.macro_profile is defined ? explain.macro_profile|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Configured Weights</p><p class="font-medium">Direct {{ explain.direct_news_weight ?? '-' }} / Context {{ explain.context_news_weight ?? '-' }}</p></div>
                <div><p class="text-slate-500">Effective Weights</p><p class="font-medium">Direct {{ explain.effective_sentiment_weights.direct ?? '-' }} / Context {{ explain.effective_sentiment_weights.context ?? '-' }}</p></div>
            </div>
        </section>
    {% endif %}

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Merge & Thresholds</h2>
        <div class="mt-4">{{ ui.threshold_bar(ticker.mergedScore, view.scorePositions.merged) }}</div>
        <p class="mt-3 text-sm text-slate-700">Scores liegen in [-1, 1]. Merged = {{ mergeWeights.kronos ?? 0.6 }} x K Norm + {{ mergeWeights.sentiment ?? 0.4 }} x S Norm. ENTRY ab 0.35, WATCH ab 0.15, HOLD zwischen -0.15 und 0.15, NO TRADE bis -0.15.</p>
    </section>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Status & Datenqualitaet</h2>
        <div class="mt-3 flex flex-wrap gap-2 text-sm">
            <span class="rounded-md bg-slate-50 px-3 py-2"><span class="text-slate-500">Mapping</span> {{ ui.status_badge(ticker.mappingStatus) }}</span>
            <span class="rounded-md bg-slate-50 px-3 py-2"><span class="text-slate-500">Market</span> {{ ui.status_badge(ticker.marketDataStatus) }}</span>
            <span class="rounded-md bg-slate-50 px-3 py-2"><span class="text-slate-500">News</span> {{ ui.status_badge(ticker.newsStatus) }}</span>
            <span class="rounded-md bg-slate-50 px-3 py-2"><span class="text-slate-500">Kronos</span> {{ ui.status_badge(ticker.kronosStatus) }}</span>
            <span class="rounded-md bg-slate-50 px-3 py-2"><span class="text-slate-500">Sentiment</span> {{ ui.status_badge(ticker.sentimentStatus) }}</span>
        </div>
        {% if ticker.mappingNote %}
            <p class="mt-4 text-sm text-slate-600">{{ ticker.mappingNote }}</p>
        {% endif %}
    </section>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm" data-controller="collapse">
        <button class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" type="button" data-action="collapse#toggle">
            <span data-collapse-target="label">Explain JSON anzeigen</span>
        </button>
        <pre class="mt-4 hidden max-h-[36rem] overflow-auto rounded-md bg-slate-950 p-4 text-xs text-slate-100" data-collapse-target="content">{{ explain|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
    </section>
{% endblock %}
