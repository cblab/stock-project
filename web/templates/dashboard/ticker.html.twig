{% extends 'base.html.twig' %}

{% block title %}{{ ticker.displayTicker }}{% endblock %}

{% block body %}
    {% set isEtf = ticker.assetClass == 'ETF' %}
    <div class="mb-6">
        <a class="text-sm text-slate-500 hover:text-slate-950" href="{{ path('app_run_show', {id: run.id}) }}">Zurueck zu Run {{ run.runId }}</a>
        <div class="mt-2 flex flex-wrap items-center gap-3">
            <h1 class="text-2xl font-semibold text-slate-950">{{ ticker.displayTicker }}</h1>
            <span class="rounded-full px-2.5 py-1 text-xs font-medium ring-1 {{ isEtf ? 'bg-violet-50 text-violet-700 ring-violet-200' : 'bg-slate-100 text-slate-700 ring-slate-200' }}">{{ ticker.assetClass }}</span>
            <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200">{{ ticker.sentimentMode ?: '-' }}</span>
        </div>
    </div>

    <div class="grid gap-4 lg:grid-cols-3">
        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500">Mapping</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Input</dt><dd class="font-medium">{{ ticker.inputTicker }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Provider</dt><dd class="font-medium">{{ ticker.providerTicker }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Region</dt><dd class="font-medium">{{ ticker.region ?: '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Status</dt><dd class="font-medium">{{ ticker.mappingStatus ?: '-' }}</dd></div>
            </dl>
            {% if ticker.mappingNote %}
                <p class="mt-3 text-sm text-slate-600">{{ ticker.mappingNote }}</p>
            {% endif %}
        </section>

        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500">Scores</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4"><dt class="text-slate-500">K Raw</dt><dd class="font-medium">{{ ticker.kronosRawScore is not null ? ticker.kronosRawScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">K Norm</dt><dd class="font-medium">{{ ticker.kronosNormalizedScore is not null ? ticker.kronosNormalizedScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">S Raw</dt><dd class="font-medium">{{ ticker.sentimentRawScore is not null ? ticker.sentimentRawScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">S Norm</dt><dd class="font-medium">{{ ticker.sentimentNormalizedScore is not null ? ticker.sentimentNormalizedScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Merged</dt><dd class="font-semibold">{{ ticker.mergedScore is not null ? ticker.mergedScore|number_format(4) : '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Decision</dt><dd class="font-semibold">{{ ticker.decision }}</dd></div>
            </dl>
        </section>

        <section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500">Status</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Market Data</dt><dd class="font-medium">{{ ticker.marketDataStatus ?: '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">News</dt><dd class="font-medium">{{ ticker.newsStatus ?: '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Kronos</dt><dd class="font-medium">{{ ticker.kronosStatus ?: '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Sentiment</dt><dd class="font-medium">{{ ticker.sentimentStatus ?: '-' }}</dd></div>
                <div class="flex justify-between gap-4"><dt class="text-slate-500">Backend</dt><dd class="font-medium">{{ ticker.sentimentBackend ?: '-' }}</dd></div>
            </dl>
        </section>
    </div>

    {% if isEtf %}
        <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-500">ETF Context</h2>
            <div class="mt-3 grid gap-4 text-sm md:grid-cols-2">
                <div><p class="text-slate-500">Benchmark</p><p class="font-medium">{{ explain.benchmark ?? '-' }}</p></div>
                <div><p class="text-slate-500">Direct News Status</p><p class="font-medium">{{ explain.direct_news_status ?? '-' }}</p></div>
                <div><p class="text-slate-500">Region Exposure</p><p class="font-medium">{{ explain.region_exposure is defined ? explain.region_exposure|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Sector Profile</p><p class="font-medium">{{ explain.sector_profile is defined ? explain.sector_profile|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Top Holdings</p><p class="font-medium">{{ explain.top_holdings_profile is defined ? explain.top_holdings_profile|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Macro Profile</p><p class="font-medium">{{ explain.macro_profile is defined ? explain.macro_profile|join(', ') : '-' }}</p></div>
                <div><p class="text-slate-500">Weights</p><p class="font-medium">Direct {{ explain.direct_news_weight ?? '-' }} / Context {{ explain.context_news_weight ?? '-' }}</p></div>
                <div><p class="text-slate-500">Reason</p><p class="font-medium">{{ explain.final_sentiment_reason ?? '-' }}</p></div>
            </div>
        </section>
    {% endif %}

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Entscheidungsgrund</h2>
        <p class="mt-2 text-sm text-slate-700">{{ explain.decision_reason ?? explain.short_reason ?? 'Keine Begruendung im Explain-JSON vorhanden.' }}</p>
    </section>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm" data-controller="collapse">
        <button class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" type="button" data-action="collapse#toggle">
            <span data-collapse-target="label">Explain JSON anzeigen</span>
        </button>
        <pre class="mt-4 hidden max-h-[36rem] overflow-auto rounded-md bg-slate-950 p-4 text-xs text-slate-100" data-collapse-target="content">{{ explain|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
    </section>
{% endblock %}
