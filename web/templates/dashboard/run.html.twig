{% extends 'base.html.twig' %}
{% import 'dashboard/_ui.html.twig' as ui %}

{% block title %}Run {{ run.runId }}{% endblock %}

{% block body %}
    {% set columns = {
        inputTicker: ['Ticker', 'vom Nutzer gewuenschtes Symbol'],
        providerTicker: ['Provider', 'tatsaechlich verwendeter Datenprovider-Ticker'],
        assetClass: ['Asset', 'Equity oder ETF'],
        region: ['Region', 'Marktregion oder Mappingregion'],
        sentimentMode: ['Sentiment Mode', 'equity_direct fuer Einzelaktien, etf_context fuer ETFs'],
        kronosNormalizedScore: ['K Norm', 'normalisierter Kronos-Score im Bereich [-1, 1]'],
        sentimentNormalizedScore: ['S Norm', 'normalisierter Sentiment-Score im Bereich [-1, 1]'],
        mergedScore: ['Merged', '60% Kronos Normalized + 40% Sentiment Normalized'],
        decision: ['Decision', 'Ergebnis nach Threshold-Logik'],
        marketDataStatus: ['Daten', 'Status der geladenen Marktdaten'],
        newsStatus: ['News', 'Status der Nachrichtenbasis']
    } %}

    <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <a class="text-sm text-slate-500 hover:text-slate-950" href="{{ path('app_runs_index') }}">Zurueck zu Runs</a>
            <h1 class="mt-1 text-2xl font-semibold text-slate-950">Run {{ run.runId }}</h1>
            <p class="mt-1 text-sm text-slate-500">{{ run.runPath }}</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm">
            <span class="font-medium text-slate-950">Kronos:</span>
            {{ run.dataFrequency ?: '-' }} Candles,
            {{ run.horizonSteps ?: '-' }} Schritte,
            {{ run.horizonLabel ?: '-' }},
            {{ run.scoreValidityHours ?: '-' }}h Gueltigkeit
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-4">
        <div class="metric-card" title="ENTRY: merged_score >= 0.35"><p class="text-xs font-semibold uppercase text-slate-500">ENTRY</p><p class="mt-2 text-xl font-semibold">{{ run.decisionEntryCount }}</p></div>
        <div class="metric-card" title="WATCH: merged_score >= 0.15 und < 0.35"><p class="text-xs font-semibold uppercase text-slate-500">WATCH</p><p class="mt-2 text-xl font-semibold">{{ run.decisionWatchCount }}</p></div>
        <div class="metric-card" title="HOLD: merged_score zwischen -0.15 und 0.15"><p class="text-xs font-semibold uppercase text-slate-500">HOLD</p><p class="mt-2 text-xl font-semibold">{{ run.decisionHoldCount }}</p></div>
        <div class="metric-card" title="NO TRADE: merged_score <= -0.15"><p class="text-xs font-semibold uppercase text-slate-500">NO TRADE</p><p class="mt-2 text-xl font-semibold">{{ run.decisionNoTradeCount }}</p></div>
    </div>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="text-sm font-semibold uppercase text-slate-500">Score-Modell</h2>
        <p class="mt-2 text-sm text-slate-700">Scores liegen in <span class="font-medium">[-1, 1]</span>. Merged = 60% Kronos Normalized + 40% Sentiment Normalized. Thresholds: ENTRY ab 0.35, WATCH ab 0.15, HOLD zwischen -0.15 und 0.15, NO TRADE bis -0.15.</p>
    </section>

    <section class="mt-6 overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
        <table class="data-table">
            <thead>
                <tr>
                    {% for field, meta in columns %}
                        {% set nextDir = currentSort == field and currentDir == 'asc' ? 'desc' : 'asc' %}
                        {% set active = currentSort == field %}
                        <th title="{{ meta[1] }}">
                            <a class="inline-flex items-center gap-1 rounded px-1 py-0.5 {{ active ? 'text-slate-950' : 'text-slate-500 hover:text-slate-950' }}" href="{{ path('app_run_show', {id: run.id, sort: field, dir: nextDir}) }}">
                                <span>{{ meta[0] }}</span>
                                <span class="text-[10px]">{{ active ? (currentDir == 'asc' ? 'ASC' : 'DESC') : 'SORT' }}</span>
                            </a>
                        </th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for ticker in tickers %}
                    <tr class="hover:bg-slate-50">
                        <td class="font-medium text-slate-950" title="Ticker: vom Nutzer gewuenschtes Symbol"><a class="underline decoration-slate-300 underline-offset-4 hover:decoration-slate-900" href="{{ path('app_ticker_show', {id: ticker.id}) }}">{{ ticker.displayTicker }}</a></td>
                        <td title="Provider-Ticker fuer Datenabfragen">{{ ticker.providerTicker }}</td>
                        <td>{{ ui.asset_badge(ticker.assetClass) }}</td>
                        <td title="Mappingregion">{{ ticker.region ?: '-' }}</td>
                        <td>{{ ui.mode_badge(ticker.sentimentMode) }}</td>
                        <td title="Normalisierter Kronos-Score [-1, 1]">{{ ticker.kronosNormalizedScore is not null ? ticker.kronosNormalizedScore|number_format(3) : '-' }}</td>
                        <td title="Normalisierter Sentiment-Score [-1, 1]">{{ ticker.sentimentNormalizedScore is not null ? ticker.sentimentNormalizedScore|number_format(3) : '-' }}</td>
                        <td class="font-medium" title="60% Kronos + 40% Sentiment">{{ ticker.mergedScore is not null ? ticker.mergedScore|number_format(3) : '-' }}</td>
                        <td>{{ ui.decision_badge(ticker.decision) }}</td>
                        <td>{{ ui.status_badge(ticker.marketDataStatus) }}</td>
                        <td>{{ ui.status_badge(ticker.newsStatus) }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
